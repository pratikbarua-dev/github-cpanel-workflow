# ========================================
# MoRPH Web Application - Environment Config
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Application Mode
NODE_ENV=production
PORT=3000

# ========================================
# Session & JWT Security (REQUIRED)
# ========================================
# Generate a secure random string (64+ characters recommended)
# Example: openssl rand -base64 48
SESSION_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_64_CHARS_MIN

# ========================================
# MySQL Database (REQUIRED for cPanel)
# ========================================
# Get these from cPanel > MySQL Databases
DB_HOST=localhost
DB_USER=cpanel_user_dbname
DB_PASS=your_database_password
DB_NAME=cpanel_user_dbname

# ========================================
# Email Service (Resend API)
# ========================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
