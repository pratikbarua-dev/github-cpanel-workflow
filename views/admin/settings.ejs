<%- include('../partials/header', { title: 'Settings' , path: '/settings' }) %>

    <main class="flex-1 overflow-y-auto p-6">
        <h1 class="text-2xl font-bold text-gray-800 mb-6">Account Settings</h1>

        <% if (locals.error) { %>
            <div class="bg-red-100 text-red-700 p-4 rounded mb-4 border border-red-200">
                <%= error %>
            </div>
            <% } %>

                <% if (locals.success) { %>
                    <div class="bg-green-100 text-green-700 p-4 rounded mb-4 border border-green-200">
                        <%= success %>
                    </div>
                    <% } %>

                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                            <!-- Account Details -->
                            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                                <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
                                    <i class="fas fa-user-circle text-teal-600"></i> Profile Info
                                </h2>
                                <form action="/admin/settings" method="POST">
                                    <div class="mb-4">
                                        <label class="block text-gray-700 text-sm font-bold mb-2">Email Address</label>
                                        <input type="email" name="email" value="<%= user.email %>" required
                                            class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-teal-500 bg-gray-50">
                                    </div>

                                    <hr class="my-6 border-gray-100">

                                    <div class="mb-4">
                                        <label class="block text-gray-700 text-sm font-bold mb-2">New Password (Leave
                                            blank
                                            to keep current)</label>
                                        <input type="password" name="new_password" placeholder="New Password"
                                            class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-teal-500">
                                    </div>

                                    <div class="mb-6">
                                        <label class="block text-gray-700 text-sm font-bold mb-2">Confirm New
                                            Password</label>
                                        <input type="password" name="confirm_password" placeholder="Confirm Password"
                                            class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-teal-500">
                                    </div>

                                    <div class="flex justify-end">
                                        <button type="submit"
                                            class="bg-teal-600 text-white px-6 py-2 rounded-lg font-bold hover:bg-teal-700 transition shadow-sm">
                                            Update Profile
                                        </button>
                                    </div>
                                </form>
                            </div>

                            <!-- CSR Sub-Sections -->
                            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                                <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
                                    <i class="fas fa-globe text-teal-600"></i> CSR Sub-Sections
                                </h2>
                                <p class="text-sm text-gray-500 mb-6">Manage the categories appearing in the CSR
                                    dropdown on the public site and in the post editor.</p>

                                <div class="space-y-3 mb-6" id="sections-list">
                                    <% csrSections.forEach((section, index)=> { %>
                                        <div class="flex items-center gap-2 section-item" data-section="<%= section %>">
                                            <input type="text" value="<%= section %>" readonly
                                                class="section-name-input flex-1 px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-teal-500 bg-gray-50">
                                            <button type="button" onclick="editSection(this)"
                                                class="p-2 text-blue-500 hover:bg-blue-50 rounded-lg transition"
                                                title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button type="button" onclick="deleteSection(this)"
                                                class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition"
                                                title="Delete">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                        <% }); %>
                                </div>

                                <div class="flex gap-2">
                                    <input type="text" id="new-section-input" placeholder="e.g. Health Equity"
                                        class="flex-1 px-4 py-2 border border-blue-200 rounded-lg focus:outline-none focus:border-blue-500">
                                    <button type="button" onclick="addSection()"
                                        class="bg-blue-50 text-blue-600 px-4 py-2 rounded-lg font-bold hover:bg-blue-100 transition">
                                        <i class="fas fa-plus mr-1"></i> Add
                                    </button>
                                </div>

                                <div id="csr-notification" class="hidden mt-4 p-3 rounded-lg text-sm"></div>
                            </div>

                            <!-- Application Types -->
                            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                                <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
                                    <i class="fas fa-file-signature text-teal-600"></i> Application Types
                                </h2>
                                <p class="text-sm text-gray-500 mb-6">Manage the options appearing in the "Application Type" dropdown on the public /apply form.</p>

                                <div class="space-y-3 mb-6" id="app-types-list">
                                    <% (locals.applicationTypes || ['Volunteer', 'Internship', 'Partnership', 'Researcher']).forEach((type, index)=> { %>
                                        <div class="flex items-center gap-2 app-type-item" data-type="<%= type %>">
                                            <input type="text" value="<%= type %>" readonly
                                                class="type-name-input flex-1 px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-teal-500 bg-gray-50">
                                            <button type="button" onclick="editAppType(this)"
                                                class="p-2 text-blue-500 hover:bg-blue-50 rounded-lg transition"
                                                title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button type="button" onclick="deleteAppType(this)"
                                                class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition"
                                                title="Delete">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                        <% }); %>
                                </div>

                                <div class="flex gap-2">
                                    <input type="text" id="new-app-type-input" placeholder="e.g. Fellow"
                                        class="flex-1 px-4 py-2 border border-blue-200 rounded-lg focus:outline-none focus:border-blue-500">
                                    <button type="button" onclick="addAppType()"
                                        class="bg-blue-50 text-blue-600 px-4 py-2 rounded-lg font-bold hover:bg-blue-100 transition">
                                        <i class="fas fa-plus mr-1"></i> Add
                                    </button>
                                </div>

                                <div id="app-type-notification" class="hidden mt-4 p-3 rounded-lg text-sm"></div>
                            </div>
                        </div>


                        <script>
                            let _settingsEditOldName = '';
                            let _settingsDeleteSection = '';

                            function showCSRNotification(message, type) {
                                const el = document.getElementById('csr-notification');
                                el.className = 'mt-4 p-3 rounded-lg text-sm';
                                el.classList.add(type === 'success' ? 'bg-green-100' : 'bg-red-100');
                                el.classList.add(type === 'success' ? 'text-green-700' : 'text-red-700');
                                el.textContent = message;
                                el.classList.remove('hidden');
                                setTimeout(() => el.classList.add('hidden'), 3000);
                            }

                            async function addSection() {
                                const input = document.getElementById('new-section-input');
                                const value = input.value.trim();
                                if (!value) return;
                                try {
                                    const response = await fetch('/admin/settings/csr-sections/api', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ section: value })
                                    });
                                    const result = await response.json();
                                    if (result.success) {
                                        rebuildSectionsList(result.sections);
                                        input.value = '';
                                        showCSRNotification('Section added successfully!', 'success');
                                    } else {
                                        showCSRNotification('Error: ' + result.error, 'error');
                                    }
                                } catch (error) {
                                    showCSRNotification('Server error', 'error');
                                }
                            }

                            function editSection(btn) {
                                const item = btn.closest('.section-item');
                                _settingsEditOldName = item.dataset.section;
                                document.getElementById('settingsEditOldName').textContent = '"' + _settingsEditOldName + '"';
                                document.getElementById('settingsEditInput').value = _settingsEditOldName;
                                document.getElementById('settingsEditModal').classList.remove('hidden');
                                setTimeout(() => document.getElementById('settingsEditInput').select(), 100);
                            }
                            function closeSettingsEditModal() { document.getElementById('settingsEditModal').classList.add('hidden'); }
                            async function confirmSettingsEdit() {
                                const newName = document.getElementById('settingsEditInput').value.trim();
                                if (!newName || newName === _settingsEditOldName) { closeSettingsEditModal(); return; }
                                try {
                                    const response = await fetch('/admin/settings/csr-sections/api', {
                                        method: 'PUT',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ oldName: _settingsEditOldName, newName })
                                    });
                                    const result = await response.json();
                                    if (result.success) {
                                        rebuildSectionsList(result.sections);
                                        showCSRNotification('Section renamed successfully!', 'success');
                                    } else {
                                        showCSRNotification('Error: ' + result.error, 'error');
                                    }
                                } catch (error) {
                                    showCSRNotification('Server error', 'error');
                                }
                                closeSettingsEditModal();
                            }

                            function deleteSection(btn) {
                                const item = btn.closest('.section-item');
                                _settingsDeleteSection = item.dataset.section;
                                document.getElementById('settingsDeleteName').textContent = '"' + _settingsDeleteSection + '"';
                                document.getElementById('settingsDeleteModal').classList.remove('hidden');
                            }
                            function closeSettingsDeleteModal() { document.getElementById('settingsDeleteModal').classList.add('hidden'); }
                            async function confirmSettingsDelete() {
                                try {
                                    const response = await fetch('/admin/settings/csr-sections/api', {
                                        method: 'DELETE',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ section: _settingsDeleteSection })
                                    });
                                    const result = await response.json();
                                    if (result.success) {
                                        rebuildSectionsList(result.sections);
                                        showCSRNotification('Section deleted successfully!', 'success');
                                    } else {
                                        showCSRNotification('Error: ' + result.error, 'error');
                                    }
                                } catch (error) {
                                    showCSRNotification('Server error', 'error');
                                }
                                closeSettingsDeleteModal();
                            }

                            function rebuildSectionsList(sections) {
                                const container = document.getElementById('sections-list');
                                container.innerHTML = '';
                                sections.forEach(section => {
                                    const div = document.createElement('div');
                                    div.className = 'flex items-center gap-2 section-item';
                                    div.dataset.section = section;
                                    div.innerHTML = `
                                        <input type="text" value="${section}" readonly
                                            class="section-name-input flex-1 px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-teal-500 bg-gray-50">
                                        <button type="button" onclick="editSection(this)"
                                            class="p-2 text-blue-500 hover:bg-blue-50 rounded-lg transition" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button type="button" onclick="deleteSection(this)"
                                            class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition" title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    `;
                                    container.appendChild(div);
                                });
                            }

                            // --- Application Types JS ---
                            let _appTypeEditOldName = '';
                            let _appTypeDeleteName = '';

                            function showAppTypeNotification(message, type) {
                                const el = document.getElementById('app-type-notification');
                                el.className = 'mt-4 p-3 rounded-lg text-sm';
                                el.classList.add(type === 'success' ? 'bg-green-100' : 'bg-red-100');
                                el.classList.add(type === 'success' ? 'text-green-700' : 'text-red-700');
                                el.textContent = message;
                                el.classList.remove('hidden');
                                setTimeout(() => el.classList.add('hidden'), 3000);
                            }

                            async function addAppType() {
                                const input = document.getElementById('new-app-type-input');
                                const value = input.value.trim();
                                if (!value) return;
                                try {
                                    const response = await fetch('/admin/settings/application-types/api', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ type: value })
                                    });
                                    const result = await response.json();
                                    if (result.success) {
                                        rebuildAppTypeList(result.types);
                                        input.value = '';
                                        showAppTypeNotification('Type added successfully!', 'success');
                                    } else {
                                        showAppTypeNotification('Error: ' + result.error, 'error');
                                    }
                                } catch (error) {
                                    showAppTypeNotification('Server error', 'error');
                                }
                            }

                            function editAppType(btn) {
                                const item = btn.closest('.app-type-item');
                                _appTypeEditOldName = item.dataset.type;
                                document.getElementById('appTypeEditOldNameDisplay').textContent = '"' + _appTypeEditOldName + '"';
                                document.getElementById('appTypeEditInput').value = _appTypeEditOldName;
                                document.getElementById('appTypeEditModal').classList.remove('hidden');
                                setTimeout(() => document.getElementById('appTypeEditInput').select(), 100);
                            }
                            function closeAppTypeEditModal() { document.getElementById('appTypeEditModal').classList.add('hidden'); }
                            async function confirmAppTypeEdit() {
                                const newName = document.getElementById('appTypeEditInput').value.trim();
                                if (!newName || newName === _appTypeEditOldName) { closeAppTypeEditModal(); return; }
                                try {
                                    const response = await fetch('/admin/settings/application-types/api', {
                                        method: 'PUT',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ oldName: _appTypeEditOldName, newName })
                                    });
                                    const result = await response.json();
                                    if (result.success) {
                                        rebuildAppTypeList(result.types);
                                        showAppTypeNotification('Type renamed successfully!', 'success');
                                    } else {
                                        showAppTypeNotification('Error: ' + result.error, 'error');
                                    }
                                } catch (error) {
                                    showAppTypeNotification('Server error', 'error');
                                }
                                closeAppTypeEditModal();
                            }

                            function deleteAppType(btn) {
                                const item = btn.closest('.app-type-item');
                                _appTypeDeleteName = item.dataset.type;
                                document.getElementById('appTypeDeleteNameDisplay').textContent = '"' + _appTypeDeleteName + '"';
                                document.getElementById('appTypeDeleteModal').classList.remove('hidden');
                            }
                            function closeAppTypeDeleteModal() { document.getElementById('appTypeDeleteModal').classList.add('hidden'); }
                            async function confirmAppTypeDelete() {
                                try {
                                    const response = await fetch('/admin/settings/application-types/api', {
                                        method: 'DELETE',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ type: _appTypeDeleteName })
                                    });
                                    const result = await response.json();
                                    if (result.success) {
                                        rebuildAppTypeList(result.types);
                                        showAppTypeNotification('Type deleted successfully!', 'success');
                                    } else {
                                        showAppTypeNotification('Error: ' + result.error, 'error');
                                    }
                                } catch (error) {
                                    showAppTypeNotification('Server error', 'error');
                                }
                                closeAppTypeDeleteModal();
                            }

                            function rebuildAppTypeList(types) {
                                const container = document.getElementById('app-types-list');
                                container.innerHTML = '';
                                types.forEach(type => {
                                    const div = document.createElement('div');
                                    div.className = 'flex items-center gap-2 app-type-item';
                                    div.dataset.type = type;
                                    div.innerHTML = `
                                        <input type="text" value="${type}" readonly
                                            class="type-name-input flex-1 px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-teal-500 bg-gray-50">
                                        <button type="button" onclick="editAppType(this)"
                                            class="p-2 text-blue-500 hover:bg-blue-50 rounded-lg transition" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button type="button" onclick="deleteAppType(this)"
                                            class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition" title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    `;
                                    container.appendChild(div);
                                });
                            }

                            document.addEventListener('keydown', e => {
                                if (e.key === 'Escape') { 
                                    closeSettingsEditModal(); 
                                    closeSettingsDeleteModal(); 
                                    closeAppTypeEditModal();
                                    closeAppTypeDeleteModal();
                                }
                                if (e.key === 'Enter') {
                                    if (!document.getElementById('settingsEditModal').classList.contains('hidden')) confirmSettingsEdit();
                                    if (!document.getElementById('appTypeEditModal').classList.contains('hidden')) confirmAppTypeEdit();
                                }
                            });
                        </script>

                        <!-- Settings Edit Modal -->
                        <div id="settingsEditModal" class="fixed inset-0 z-50 hidden">
                            <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"
                                onclick="closeSettingsEditModal()"></div>
                            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white rounded-2xl shadow-2xl w-full max-w-md p-6"
                                style="animation: modalIn 0.2s ease-out">
                                <div class="flex items-center gap-3 mb-4">
                                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                                        <i class="fas fa-edit text-blue-600"></i>
                                    </div>
                                    <h3 class="text-lg font-bold text-gray-800">Rename Section</h3>
                                </div>
                                <p class="text-sm text-gray-500 mb-4">Enter a new name for <strong
                                        id="settingsEditOldName"></strong></p>
                                <input type="text" id="settingsEditInput"
                                    class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 text-sm mb-6"
                                    placeholder="New section name">
                                <div class="flex justify-end gap-3">
                                    <button onclick="closeSettingsEditModal()"
                                        class="px-5 py-2.5 text-gray-600 hover:bg-gray-100 rounded-xl text-sm font-semibold transition">Cancel</button>
                                    <button onclick="confirmSettingsEdit()"
                                        class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-sm font-semibold transition shadow-sm">Rename</button>
                                </div>
                            </div>
                        </div>

                        <!-- Settings Delete Modal -->
                        <div id="settingsDeleteModal" class="fixed inset-0 z-50 hidden">
                            <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"
                                onclick="closeSettingsDeleteModal()"></div>
                            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white rounded-2xl shadow-2xl w-full max-w-md p-6"
                                style="animation: modalIn 0.2s ease-out">
                                <div class="flex items-center gap-3 mb-4">
                                    <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                                        <i class="fas fa-exclamation-triangle text-red-600"></i>
                                    </div>
                                    <h3 class="text-lg font-bold text-gray-800">Delete Section</h3>
                                </div>
                                <p class="text-sm text-gray-600 mb-2">Are you sure you want to delete <strong
                                        id="settingsDeleteName"></strong>?</p>
                                <p class="text-xs text-red-500 mb-6"><i class="fas fa-info-circle mr-1"></i>All posts
                                    under this section will also be deleted.</p>
                                <div class="flex justify-end gap-3">
                                    <button onclick="closeSettingsDeleteModal()"
                                        class="px-5 py-2.5 text-gray-600 hover:bg-gray-100 rounded-xl text-sm font-semibold transition">Cancel</button>
                                    <button onclick="confirmSettingsDelete()"
                                        class="px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-xl text-sm font-semibold transition shadow-sm">Delete</button>
                                </div>
                            </div>
                        </div>

                        <!-- Application Type Edit Modal -->
                        <div id="appTypeEditModal" class="fixed inset-0 z-50 hidden">
                            <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"
                                onclick="closeAppTypeEditModal()"></div>
                            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white rounded-2xl shadow-2xl w-full max-w-md p-6"
                                style="animation: modalIn 0.2s ease-out">
                                <div class="flex items-center gap-3 mb-4">
                                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                                        <i class="fas fa-edit text-blue-600"></i>
                                    </div>
                                    <h3 class="text-lg font-bold text-gray-800">Rename Type</h3>
                                </div>
                                <p class="text-sm text-gray-500 mb-4">Enter a new name for <strong
                                        id="appTypeEditOldNameDisplay"></strong></p>
                                <input type="text" id="appTypeEditInput"
                                    class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 text-sm mb-6"
                                    placeholder="New type name">
                                <div class="flex justify-end gap-3">
                                    <button onclick="closeAppTypeEditModal()"
                                        class="px-5 py-2.5 text-gray-600 hover:bg-gray-100 rounded-xl text-sm font-semibold transition">Cancel</button>
                                    <button onclick="confirmAppTypeEdit()"
                                        class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-sm font-semibold transition shadow-sm">Rename</button>
                                </div>
                            </div>
                        </div>

                        <!-- Application Type Delete Modal -->
                        <div id="appTypeDeleteModal" class="fixed inset-0 z-50 hidden">
                            <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"
                                onclick="closeAppTypeDeleteModal()"></div>
                            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white rounded-2xl shadow-2xl w-full max-w-md p-6"
                                style="animation: modalIn 0.2s ease-out">
                                <div class="flex items-center gap-3 mb-4">
                                    <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                                        <i class="fas fa-exclamation-triangle text-red-600"></i>
                                    </div>
                                    <h3 class="text-lg font-bold text-gray-800">Delete Type</h3>
                                </div>
                                <p class="text-sm text-gray-600 mb-6">Are you sure you want to delete <strong
                                        id="appTypeDeleteNameDisplay"></strong>? Existing applications with this type will remain in the database but the option will be removed from the public form.</p>
                                <div class="flex justify-end gap-3">
                                    <button onclick="closeAppTypeDeleteModal()"
                                        class="px-5 py-2.5 text-gray-600 hover:bg-gray-100 rounded-xl text-sm font-semibold transition">Cancel</button>
                                    <button onclick="confirmAppTypeDelete()"
                                        class="px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-xl text-sm font-semibold transition shadow-sm">Delete</button>
                                </div>
                            </div>
                        </div>

                        <style>
                            @keyframes modalIn {
                                from {
                                    opacity: 0;
                                    transform: translate(-50%, -50%) scale(0.95);
                                }

                                to {
                                    opacity: 1;
                                    transform: translate(-50%, -50%) scale(1);
                                }
                            }
                        </style>

    </main>

    <%- include('partials/footer') %>