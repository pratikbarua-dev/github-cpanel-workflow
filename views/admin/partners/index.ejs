<%- include('../partials/header', { title: 'Partners' , path: '/partners' }) %>

    <main class="flex-grow overflow-y-auto p-6">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold text-gray-800">Manage Partners</h1>
            <a href="/admin/partners/new"
                class="bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition shadow-sm">
                <i class="fas fa-plus mr-2"></i> Add Partner
            </a>
        </div>

        <!-- Partners Table -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 text-gray-500 text-xs uppercase font-semibold">
                        <tr>
                            <th class="px-6 py-3">Logo</th>
                            <th class="px-6 py-3">Name</th>
                            <th class="px-6 py-3">Category</th>
                            <th class="px-6 py-3">Display Order</th>
                            <th class="px-6 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% if (partners.length > 0) { %>
                            <% partners.forEach(function(partner) { %>
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="px-6 py-4">
                                        <% if (partner.logo_url) { %>
                                            <img src="<%= partner.logo_url %>" alt="<%= partner.name %>"
                                                class="w-12 h-12 object-contain border border-gray-100 p-1 rounded bg-white">
                                        <% } else { %>
                                            <div class="w-12 h-12 flex items-center justify-center border border-gray-100 rounded bg-gray-50 text-[10px] text-gray-400 font-bold uppercase text-center leading-tight">
                                                No Logo
                                            </div>
                                        <% } %>
                                    </td>
                                    <td class="px-6 py-4 text-sm font-semibold text-gray-800">
                                        <%= partner.name %>
                                    </td>
                                    <td class="px-6 py-4 text-sm">
                                        <% if (partner.category === 'academic') { %>
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                                Academic Partner
                                            </span>
                                        <% } else if (partner.category === 'network') { %>
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                                Network & Forum
                                            </span>
                                        <% } else if (partner.category === 'un_gov') { %>
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800">
                                                UN & Government
                                            </span>
                                        <% } else { %>
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                                <%= partner.category %>
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        <%= partner.display_order %>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <a href="/admin/partners/<%= partner.id %>/edit"
                                                class="text-blue-600 hover:text-blue-800" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form action="/admin/partners/<%= partner.id %>/delete" method="POST"
                                                onsubmit="return confirm('Are you sure you want to delete this partner?');">
                                                <button type="submit" class="text-red-500 hover:text-red-700"
                                                    title="Delete">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="px-6 py-8 text-center text-gray-500">No partners found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
