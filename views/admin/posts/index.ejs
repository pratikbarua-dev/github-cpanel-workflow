<%- include('../partials/header', { title: 'Posts & News' , path: '/posts' }) %>

    <main class="flex-1 overflow-y-auto p-6">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold text-gray-800">Manage Posts & News</h1>
            <a href="/admin/posts/new"
                class="bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition shadow-sm">
                <i class="fas fa-plus mr-2"></i> Add New Post
            </a>
        </div>

        <!-- Posts Table -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 text-gray-500 text-xs uppercase font-semibold">
                        <tr>
                            <th class="px-6 py-3">Image</th>
                            <th class="px-6 py-3">Title</th>
                            <th class="px-6 py-3">Type</th>
                            <th class="px-6 py-3">Status</th>
                            <th class="px-6 py-3">Date</th>
                            <th class="px-6 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% if (posts.length> 0) { %>
                            <% posts.forEach(function(post) { %>
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="px-6 py-4">
                                        <img src="<%= post.image_url || 'https://placehold.co/100?text=No+Img' %>"
                                            class="w-12 h-12 rounded object-cover border border-gray-200">
                                    </td>
                                    <td class="px-6 py-4 text-sm font-semibold text-gray-800">
                                        <%= post.title %>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span
                                            class="px-2 py-1 text-xs font-semibold rounded-full <%= post.type === 'Event' ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700' %>">
                                            <%= post.type %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        <%= post.date %>
                                    </td>
                                    <td class="px-6 py-4">
                                        <% if (post.status==='published' ) { %>
                                            <span
                                                class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-700">Published</span>
                                            <% } else if (post.status==='archived' ) { %>
                                                <span
                                                    class="px-2 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-700">Archived</span>
                                                <% } else { %>
                                                    <span
                                                        class="px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-700">Draft</span>
                                                    <% } %>
                                    </td>
                                    <td class="px-6 py-4 flex gap-3">
                                        <!-- Quick Publish/Unpublish -->
                                        <% if (post.status==='published' ) { %>
                                            <form action="/admin/posts/<%= post.id %>/status" method="POST"
                                                title="Unpublish (Set to Draft)">
                                                <input type="hidden" name="status" value="draft">
                                                <button type="submit" class="text-yellow-600 hover:text-yellow-800">
                                                    <i class="fas fa-eye-slash"></i>
                                                </button>
                                            </form>
                                            <% } else { %>
                                                <form action="/admin/posts/<%= post.id %>/status" method="POST"
                                                    title="Publish Now">
                                                    <input type="hidden" name="status" value="published">
                                                    <button type="submit" class="text-green-600 hover:text-green-800">
                                                        <i class="fas fa-paper-plane"></i>
                                                    </button>
                                                </form>
                                                <% } %>

                                                    <a href="/admin/posts/<%= post.id %>/edit"
                                                        class="text-blue-600 hover:text-blue-800" title="Edit">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form action="/admin/posts/<%= post.id %>/delete" method="POST"
                                                        onsubmit="return confirm('Are you sure?');">
                                                        <button type="submit" class="text-red-500 hover:text-red-700"
                                                            title="Delete">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </button>
                                                    </form>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="5" class="px-6 py-8 text-center text-gray-500">No posts found.
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>