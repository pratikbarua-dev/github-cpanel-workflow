<%- include('partials/header', { title: title , path: path }) %>

    <main class="flex-1 overflow-y-auto bg-slate-50 p-6 md:p-8">
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-slate-800">Search Results</h1>
            <p class="text-slate-500 text-sm mt-1">Showing results for "<span class="font-semibold text-slate-700">
                    <%= query %>
                </span>"</p>
        </div>

        <% if (projects.length===0 && posts.length===0 && publications.length===0) { %>
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-12 text-center text-slate-500">
                <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-search text-2xl text-slate-400"></i>
                </div>
                <h3 class="text-lg font-medium text-slate-800">No results found</h3>
                <p class="mt-2">Try adjusting your search terms or filters.</p>
                <a href="/admin/dashboard"
                    class="inline-block mt-4 px-4 py-2 bg-brand-600 text-white rounded-lg text-sm hover:bg-brand-700 transition">Back
                    to Dashboard</a>
            </div>
            <% } %>

                <div class="space-y-8">
                    <% if (projects.length> 0) { %>
                        <div>
                            <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
                                <i class="fas fa-project-diagram text-brand-500"></i> Projects
                            </h2>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <% projects.forEach(item=> { %>
                                    <a href="/admin/projects/<%= item.id %>/edit"
                                        class="block bg-white p-4 rounded-xl shadow-sm border border-slate-100 hover:shadow-md hover:border-brand-200 transition">
                                        <h3 class="font-bold text-slate-800 mb-1">
                                            <%= item.title %>
                                        </h3>
                                        <p class="text-xs text-slate-500 truncate">
                                            <%= item.summary || 'No summary' %>
                                        </p>
                                    </a>
                                    <% }) %>
                            </div>
                        </div>
                        <% } %>

                            <% if (posts.length> 0) { %>
                                <div>
                                    <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
                                        <i class="fas fa-newspaper text-emerald-500"></i> Posts
                                    </h2>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <% posts.forEach(item=> { %>
                                            <a href="/admin/posts/<%= item.id %>/edit"
                                                class="block bg-white p-4 rounded-xl shadow-sm border border-slate-100 hover:shadow-md hover:border-emerald-200 transition">
                                                <h3 class="font-bold text-slate-800 mb-1">
                                                    <%= item.title %>
                                                </h3>
                                                <p class="text-xs text-slate-500 truncate">
                                                    <%= item.excerpt || 'No excerpt' %>
                                                </p>
                                            </a>
                                            <% }) %>
                                    </div>
                                </div>
                                <% } %>

                                    <% if (publications.length> 0) { %>
                                        <div>
                                            <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
                                                <i class="fas fa-book text-purple-500"></i> Publications
                                            </h2>
                                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                <% publications.forEach(item=> { %>
                                                    <a href="/admin/publications/<%= item.id %>/edit"
                                                        class="block bg-white p-4 rounded-xl shadow-sm border border-slate-100 hover:shadow-md hover:border-purple-200 transition">
                                                        <h3 class="font-bold text-slate-800 mb-1">
                                                            <%= item.title %>
                                                        </h3>
                                                        <p class="text-xs text-slate-500">
                                                            <%= new Date(item.published_date).toDateString() %>
                                                        </p>
                                                    </a>
                                                    <% }) %>
                                            </div>
                                        </div>
                                        <% } %>
                </div>
    </main>

    <%- include('partials/footer') %>