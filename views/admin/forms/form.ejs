<%- include('../../partials/header', { title: form.id ? 'Edit Form' : 'New Form' , path: '/forms' }) %>

    <main class="flex-1 overflow-y-auto p-6">
        <div class="max-w-2xl mx-auto">
            <a href="/admin/forms" class="text-gray-500 hover:text-teal-600 text-sm flex items-center gap-1 mb-4">
                <i class="fas fa-arrow-left"></i> Back to Forms
            </a>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
                <h1 class="text-2xl font-bold text-gray-800 mb-6">
                    <%= form.id ? 'Edit Form' : 'Create New Form' %>
                </h1>

                <form action="/admin/forms" method="POST" class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Form Title</label>
                        <input type="text" name="title" value="<%= form.title || '' %>" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:outline-none transition">
                        <p class="text-xs text-gray-400 mt-1">This will be used for the page header.</p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                        <textarea name="description" rows="3"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:outline-none transition"><%= form.description || '' %></textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                        <select name="status"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:outline-none bg-white">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>

                    <div class="pt-4">
                        <button type="submit"
                            class="w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 rounded-lg shadow-sm transition">
                            <%= form.id ? 'Save Changes' : 'Create & Open Builder' %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <%- include('../../partials/footer') %>