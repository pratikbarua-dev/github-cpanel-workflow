<%- include('../../partials/header', { title: 'Form Responses', path: '/forms' }) %>

<main class="flex-1 overflow-y-auto p-6">
    <div class="max-w-6xl mx-auto">
        <div class="flex justify-between items-center mb-6">
            <div>
                <a href="/admin/forms"
                    class="text-gray-500 hover:text-teal-600 text-sm flex items-center gap-1 mb-1">
                    <i class="fas fa-arrow-left"></i> Back to Forms
                </a>
                <h1 class="text-2xl font-bold text-gray-800">Responses: <%= form.title %></h1>
            </div>
            <div class="flex items-center gap-4">
                <div class="text-sm text-gray-500">
                    Total: <%= form.form_responses ? form.form_responses.length : 0 %>
                </div>
                <a href="/admin/forms/<%= form.id %>/export"
                    class="bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2">
                    <i class="fas fa-download"></i> Export CSV
                </a>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-x-auto">
            <table class="w-full text-left whitespace-nowrap">
                <thead class="bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4 font-semibold text-gray-600 text-sm">Date</th>
                        <% if (form.form_fields && form.form_fields.length > 0) { %>
                            <% form.form_fields.forEach(field => { %>
                                <th class="px-6 py-4 font-semibold text-gray-600 text-sm">
                                    <%= field.label %>
                                </th>
                            <% }); %>
                        <% } else { %>
                            <th class="px-6 py-4 font-semibold text-gray-600 text-sm">Data</th>
                        <% } %>
                        <th class="px-6 py-4 font-semibold text-gray-600 text-sm text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <% if (form.form_responses && form.form_responses.length > 0) { %>
                        <% form.form_responses.forEach(response => {
                            let data = {};
                            try { data = JSON.parse(response.data); } catch(e) {}
                        %>
                            <tr class="hover:bg-gray-50 transition group">
                                <td class="px-6 py-4 text-gray-500 text-sm">
                                    <%= response.createdAt.toLocaleString() %>
                                </td>
                                <% if (form.form_fields && form.form_fields.length > 0) { %>
                                    <% form.form_fields.forEach(field => { %>
                                        <td class="px-6 py-4 text-gray-800 text-sm">
                                            <%= data[field.name] || '-' %>
                                        </td>
                                    <% }); %>
                                <% } else { %>
                                    <td class="px-6 py-4 text-gray-800 text-sm font-mono text-xs">
                                        <%= response.data %>
                                    </td>
                                <% } %>
                                <td class="px-6 py-4 text-center">
                                    <div class="flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <a href="/admin/submissions/<%= response.id %>?type=custom"
                                            class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition"
                                            title="View Details">
                                            <i class="far fa-eye"></i> View
                                        </a>
                                        <form action="/admin/submissions/<%= response.id %>/delete?type=custom" method="POST" 
                                            class="inline" onsubmit="return confirm('Are you sure you want to delete this response?');">
                                            <button type="submit"
                                                class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition"
                                                title="Delete">
                                                <i class="far fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="100%" class="px-6 py-12 text-center text-gray-400">
                                <div class="flex flex-col items-center">
                                    <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                                        <i class="far fa-folder-open text-2xl"></i>
                                    </div>
                                    <p class="text-sm font-medium">No responses received yet.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('../../partials/footer') %>
