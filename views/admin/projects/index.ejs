<%- include('../partials/header', { title: 'Projects' , path: '/projects' }) %>

    <main class="flex-1 overflow-y-auto p-6">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold text-gray-800">Manage Projects</h1>
            <a href="/admin/projects/new"
                class="bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition shadow-sm">
                <i class="fas fa-plus mr-2"></i> Add New Project
            </a>
        </div>

        <!-- Projects Table -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 text-gray-500 text-xs uppercase font-semibold">
                        <tr>
                            <th class="px-6 py-3">Image</th>
                            <th class="px-6 py-3">Title</th>
                            <th class="px-6 py-3">Status</th>
                            <th class="px-6 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% if (projects.length> 0) { %>
                            <% projects.forEach(function(project) { %>
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="px-6 py-4">
                                        <img src="<%= project.image_url || 'https://placehold.co/100?text=No+Img' %>"
                                            class="w-12 h-12 rounded object-cover border border-gray-200">
                                    </td>
                                    <td class="px-6 py-4 text-sm font-semibold text-gray-800">
                                        <%= project.title %>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span
                                            class="px-2 py-1 text-xs font-semibold rounded-full <%= project.status === 'Ongoing' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700' %>">
                                            <%= project.status %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 flex gap-3">
                                        <a href="/admin/projects/<%= project.id %>/edit"
                                            class="text-blue-600 hover:text-blue-800" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form action="/admin/projects/<%= project.id %>/delete" method="POST"
                                            onsubmit="return confirm('Are you sure?');">
                                            <button type="submit" class="text-red-500 hover:text-red-700"
                                                title="Delete">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" class="px-6 py-8 text-center text-gray-500">No projects
                                                found.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>