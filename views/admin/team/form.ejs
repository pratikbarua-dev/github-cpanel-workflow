<%- include('../partials/header', { title: member.id ? 'Edit Member' : 'New Member' , path: '/team' }) %>

    <!-- Quill CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <link href="https://cdn.tailwindcss.com" rel="stylesheet">

    <main class="flex-1 overflow-y-auto p-6">
        <div class="max-w-5xl mx-auto">
            <div class="flex justify-between items-center mb-6">
                <div>
                    <a href="/admin/team"
                        class="text-gray-500 hover:text-teal-600 text-sm flex items-center gap-1 mb-1">
                        <i class="fas fa-arrow-left"></i> Back to Team
                    </a>
                    <h1 class="text-2xl font-bold text-gray-800">
                        <%= member.id ? 'Edit Member' : 'Add New Member' %>
                    </h1>
                </div>
                <div class="flex gap-3">
                    <button type="button" onclick="saveMember()"
                        class="bg-teal-600 text-white hover:bg-teal-700 px-6 py-2.5 rounded-lg font-bold shadow-sm transition transform active:scale-95">
                        Save Member
                    </button>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
                <form id="teamForm" class="space-y-6">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Name -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                            <input type="text" id="name" value="<%= member.name || '' %>" required
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none">
                        </div>

                        <!-- Role -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Role / Position</label>
                            <input type="text" id="role" value="<%= member.role || '' %>" required
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Order -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Display Order</label>
                            <input type="number" id="display_order" value="<%= member.display_order || 0 %>"
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none">
                        </div>

                        <!-- Email -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                            <input type="email" id="email" value="<%= member.email || '' %>"
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- LinkedIn -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">LinkedIn URL</label>
                            <input type="url" id="linkedin" value="<%= member.linkedin || '' %>"
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none">
                        </div>
                        <div></div> <!-- Spacer -->
                    </div>

                    <!-- Profile Image Section -->
                    <div class="border border-gray-200 rounded-lg p-4 bg-gray-50">
                        <label class="block text-sm font-semibold text-gray-700 mb-3">
                            <i class="fas fa-user-circle mr-1 text-teal-600"></i> Profile Image
                        </label>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">Image URL</label>
                                <input type="text" id="image_url" value="<%= member.image_url || '' %>"
                                    placeholder="/images/team/member.png" onchange="previewProfileImage()"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none text-sm">
                            </div>
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">Or Upload Image</label>
                                <input type="file" id="profile_image_file" accept="image/*"
                                    onchange="handleImageUpload(this)"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg bg-white text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-teal-50 file:text-teal-700 file:font-medium hover:file:bg-teal-100">
                            </div>
                        </div>
                        <div id="profile_image_preview" class="mt-3 hidden">
                            <p class="text-xs text-gray-500 mb-1">Preview:</p>
                            <img id="preview_img" src="" alt="Preview"
                                class="w-32 h-32 rounded-full object-cover border-2 border-gray-200 shadow-sm">
                        </div>
                    </div>

                    <!-- Quill Editor for Bio -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-500 uppercase tracking-wider mb-2">Bio /
                            Description</label>
                        <div id="editor-container" class="bg-white border border-gray-200 rounded-lg"
                            style="height: 200px;">
                            <%- member.bio || '' %>
                        </div>
                    </div>

                    <!-- Quill Editor for Education -->
                    <div>
                        <label
                            class="block text-sm font-semibold text-gray-500 uppercase tracking-wider mb-2">Educational
                            Background (HTML)</label>
                        <div id="education-editor" class="bg-white border border-gray-200 rounded-lg"
                            style="height: 200px;">
                            <%- member.education || '' %>
                        </div>
                        <p class="text-xs text-gray-400 mt-1">Use bullet list for degrees/certifications</p>
                    </div>

                    <!-- Notification -->
                    <div id="notification" class="hidden p-4 rounded-lg bg-blue-50 text-blue-700 text-sm">Saving...
                    </div>

                </form>
            </div>
        </div>
    </main>

    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        var quill = new Quill('#editor-container', {
            theme: 'snow',
            modules: {
                toolbar: [
                    ['bold', 'italic', 'underline'],
                    [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                    [{ 'align': [] }],
                    ['link'],
                    ['clean']
                ]
            }
        });

        var educationQuill = new Quill('#education-editor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    ['bold', 'italic'],
                    [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                    [{ 'align': [] }],
                    ['clean']
                ]
            }
        });

        // Profile image preview from URL
        function previewProfileImage() {
            const url = document.getElementById('image_url').value;
            const previewContainer = document.getElementById('profile_image_preview');
            const previewImg = document.getElementById('preview_img');

            if (url) {
                previewImg.src = url;
                previewContainer.classList.remove('hidden');
            } else {
                previewContainer.classList.add('hidden');
            }
        }

        // Handle file upload and convert to base64
        function handleImageUpload(input) {
            const file = input.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const base64 = e.target.result;
                    document.getElementById('image_url').value = base64;
                    document.getElementById('preview_img').src = base64;
                    document.getElementById('profile_image_preview').classList.remove('hidden');
                };
                reader.readAsDataURL(file);
            }
        }

        // Initialize preview on load if there's an existing image
        document.addEventListener('DOMContentLoaded', function () {
            const existingUrl = document.getElementById('image_url').value;
            if (existingUrl) {
                previewProfileImage();
            }
        });

        async function saveMember() {
            const notification = document.getElementById('notification');
            notification.classList.remove('hidden', 'bg-red-100', 'text-red-700', 'bg-green-100', 'text-green-700');
            notification.classList.add('bg-blue-100', 'text-blue-700');
            notification.textContent = 'Saving...';
            notification.classList.remove('hidden');

            const name = document.getElementById('name').value;
            const role = document.getElementById('role').value;
            const display_order = document.getElementById('display_order').value;
            const email = document.getElementById('email').value;
            const linkedin = document.getElementById('linkedin').value;
            const image_url = document.getElementById('image_url').value;
            const bio = quill.root.innerHTML;
            const education = educationQuill.root.innerHTML;

            if (!name.trim()) {
                notification.textContent = "Name is required!";
                notification.classList.replace('bg-blue-100', 'bg-red-100');
                notification.classList.replace('text-blue-700', 'text-red-700');
                return;
            }

            const data = { name, role, display_order, email, linkedin, image_url, bio, education };

            const memberId = '<%= member.id %>';
            const url = memberId ? `/admin/team/${memberId}/api` : '/admin/team/api/create';
            const method = 'POST';

            try {
                const response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    notification.textContent = 'Member saved successfully! Redirecting...';
                    notification.classList.replace('bg-blue-100', 'bg-green-100');
                    notification.classList.replace('text-blue-700', 'text-green-700');
                    setTimeout(() => window.location.href = '/admin/team', 1000);
                } else {
                    throw new Error(result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                notification.textContent = 'Error: ' + error.message;
                notification.classList.replace('bg-blue-100', 'bg-red-100');
                notification.classList.replace('text-blue-700', 'text-red-700');
            }
        }
    </script>

    <%- include('../partials/footer') %>