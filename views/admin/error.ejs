<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - MoRPH Admin
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50 flex items-center justify-center min-h-screen p-6">

    <div class="max-w-xl w-full bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
        <!-- Header Strip -->
        <div class="h-2 bg-gradient-to-r from-red-500 to-orange-500"></div>

        <div class="p-8">
            <div class="flex flex-col items-center text-center">
                <!-- Icon -->
                <div class="mb-6 relative">
                    <div class="absolute inset-0 bg-red-100 rounded-full animate-ping opacity-75"></div>
                    <div class="relative bg-red-50 p-4 rounded-full">
                        <i class="fas fa-shield-alt text-5xl text-red-500"></i>
                    </div>
                </div>

                <!-- Main Title & Message -->
                <h1 class="text-3xl font-bold text-gray-900 mb-2">
                    <%= title || 'Access Denied' %>
                </h1>
                <p class="text-gray-500 text-lg mb-8 leading-relaxed">
                    <%= message || 'You do not have the necessary privileges to view this page.' %>
                </p>

                <!-- Detailed Reason / Help Text -->
                <% if (typeof reason !=='undefined' && reason) { %>
                    <div class="w-full bg-slate-50 rounded-lg p-5 mb-8 text-center">
                        <p class="text-slate-600 text-sm leading-relaxed">
                            <%- reason %>
                        </p>
                    </div>
                    <% } %>

                        <!-- Actions -->
                        <div class="flex flex-col sm:flex-row gap-3 w-full justify-center">
                            <button onclick="history.back()"
                                class="px-6 py-3 rounded-lg border border-gray-300 text-gray-700 font-medium hover:bg-gray-50 transition shadow-sm flex items-center justify-center">
                                <i class="fas fa-arrow-left mr-2"></i> Go Back
                            </button>
                            <a href="/admin/dashboard"
                                class="px-6 py-3 rounded-lg bg-gray-900 text-white font-medium hover:bg-gray-800 transition shadow-lg shadow-gray-900/20 flex items-center justify-center">
                                <i class="fas fa-home mr-2"></i> Return to Dashboard
                            </a>
                        </div>
            </div>
        </div>

        <!-- Footer Info -->
        <div
            class="bg-gray-50 px-8 py-4 border-t border-gray-100 flex justify-between items-center text-xs text-gray-400">
            <span>MoRPH Admin Panel</span>
            <span>
                <%= new Date().toISOString().split('T')[0] %>
            </span>
        </div>
    </div>

</body>

</html>