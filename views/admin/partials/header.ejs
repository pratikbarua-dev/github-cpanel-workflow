<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - MoRPH Admin
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/jpeg" href="/images/logo.jpg">
    <link rel="stylesheet" href="/css/magic-sidebar.css">

    <!-- TinyMCE -->
    <script src="https://cdn.tiny.cloud/1/jw3r8mrkejtc080xhfbysyr7d2nzumb5hu1ss4c1ut12pjd1/tinymce/6/tinymce.min.js"
        referrerpolicy="origin"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            900: '#1e3a8a',
                        }
                    }
                }
            }
        }

        tinymce.init({
            selector: 'textarea.rich-text',
            plugins: 'anchor autolink charmap codesample emoticons image link lists media searchreplace table visualblocks wordcount',
            toolbar: 'undo redo | blocks fontfamily fontsize | bold italic underline strikethrough | link image media table | align lineheight | numlist bullist indent outdent | emoticons charmap | removeformat',
            menubar: false,
            statusbar: false,
            height: 300
        });
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 antialiased selection:bg-brand-500 selection:text-white">

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <%- include('sidebar', {path: path}) %>

            <!-- Main Content Wrapper -->
            <div class="flex-1 flex flex-col h-full overflow-hidden ml-0 md:ml-[80px] transition-all duration-300 relative w-full"
                id="main-content">

                <!-- Top Navbar -->
                <header
                    class="h-16 bg-white/80 backdrop-blur-md border-b border-gray-200 flex items-center justify-between px-4 sm:px-6 z-20 sticky top-0">
                    <div class="flex items-center gap-4">
                        <button id="openSidebar"
                            class="md:hidden text-slate-500 hover:text-slate-700 focus:outline-none p-1 rounded-md hover:bg-slate-100 transition">
                            <i class="fas fa-bars text-xl"></i>
                        </button>
                        <!-- Search Bar -->
                        <form action="/admin/search" method="GET"
                            class="hidden sm:flex items-center bg-slate-100 rounded-lg px-3 py-2 w-64 border border-transparent focus-within:border-brand-300 focus-within:bg-white transition">
                            <button type="submit" class="focus:outline-none"><i
                                    class="fas fa-search text-slate-400 text-sm hover:text-brand-600 transition"></i></button>
                            <input type="text" name="q" placeholder="Search..."
                                class="bg-transparent border-none outline-none text-sm ml-2 w-full text-slate-700 placeholder-slate-400">
                        </form>
                    </div>

                    <div class="flex items-center gap-3 sm:gap-4">
                        <!-- Notifications -->
                        <div class="relative">
                            <button id="notificationBtn"
                                class="relative p-2 text-slate-400 hover:text-slate-600 transition rounded-full hover:bg-slate-100 focus:outline-none">
                                <i class="far fa-bell text-lg"></i>
                                <span id="notificationBadge"
                                    class="hidden absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border border-white"></span>
                            </button>
                            <!-- Notification Dropdown -->
                            <div id="notificationMenu"
                                class="hidden absolute right-0 mt-2 w-72 bg-white rounded-xl shadow-lg border border-slate-100 z-50 py-2">
                                <div class="px-4 py-2 border-b border-slate-50 flex items-center justify-between">
                                    <h3 class="text-xs font-semibold text-slate-500 uppercase">Notifications</h3>
                                    <span id="notificationCount" class="text-xs text-slate-400"></span>
                                </div>
                                <div id="notificationList" class="py-2 max-h-80 overflow-y-auto">
                                    <div class="px-4 py-3 text-center text-slate-400 text-xs">
                                        <i class="fas fa-spinner fa-spin mr-1"></i> Loading...
                                    </div>
                                </div>
                                <div class="px-4 py-2 border-t border-slate-50 text-center">
                                    <a href="/admin/dashboard"
                                        class="text-xs text-brand-600 hover:text-brand-700 font-medium">View
                                        Dashboard</a>
                                </div>
                            </div>
                        </div>

                        <!-- Profile Dropdown Trigger -->
                        <div class="relative flex items-center gap-3 pl-3 border-l border-gray-200">
                            <button id="profileBtn"
                                class="flex items-center gap-3 focus:outline-none hover:bg-slate-50 p-1 pr-2 rounded-lg transition">
                                <div class="text-right hidden sm:block">
                                    <p class="text-sm font-semibold text-slate-700">
                                        <%= user ? (user.name || user.email) : 'Admin User' %>
                                    </p>
                                    <p class="text-xs text-slate-500 capitalize">
                                        <%= user ? user.role : 'Administrator' %>
                                    </p>
                                </div>
                                <div
                                    class="w-9 h-9 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center font-bold border border-brand-200">
                                    A
                                </div>
                            </button>

                            <!-- Profile Dropdown -->
                            <div id="profileMenu"
                                class="hidden absolute right-0 top-full mt-2 w-48 bg-white rounded-xl shadow-lg border border-slate-100 z-50 py-1">
                                <div class="px-4 py-3 border-b border-slate-50 mb-1">
                                    <p class="text-sm font-medium text-slate-800">
                                        <%= user ? (user.name || 'User' ) : 'Admin User' %>
                                    </p>
                                    <p class="text-xs text-slate-500">
                                        <%= user ? user.email : 'admin@morph.com' %>
                                    </p>
                                </div>
                                <a href="/admin/settings"
                                    class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-600 transition"><i
                                        class="fas fa-cog w-5 text-center mr-2"></i> Settings</a>
                                <a href="/admin/logout"
                                    class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition"><i
                                        class="fas fa-sign-out-alt w-5 text-center mr-2"></i> Logout</a>
                            </div>
                        </div>
                    </div>
                </header>

                <script>
                    // Dropdown elements
                    const notifBtn = document.getElementById('notificationBtn');
                    const notifMenu = document.getElementById('notificationMenu');
                    const notifList = document.getElementById('notificationList');
                    const notifBadge = document.getElementById('notificationBadge');
                    const notifCount = document.getElementById('notificationCount');
                    const profileBtn = document.getElementById('profileBtn');
                    const profileMenu = document.getElementById('profileMenu');

                    // Format relative time
                    function timeAgo(dateString) {
                        const now = new Date();
                        const date = new Date(dateString);
                        const seconds = Math.floor((now - date) / 1000);

                        if (seconds < 60) return 'Just now';
                        if (seconds < 3600) return Math.floor(seconds / 60) + ' min ago';
                        if (seconds < 86400) return Math.floor(seconds / 3600) + ' hours ago';
                        if (seconds < 604800) return Math.floor(seconds / 86400) + ' days ago';
                        return date.toLocaleDateString();
                    }

                    // Get notification icon by type
                    function getNotifIcon(type) {
                        switch (type) {
                            case 'submission': return '<i class="fas fa-envelope text-blue-500"></i>';
                            case 'form_response': return '<i class="fas fa-file-alt text-green-500"></i>';
                            case 'comment': return '<i class="fas fa-comment text-purple-500"></i>';
                            default: return '<i class="fas fa-bell text-slate-400"></i>';
                        }
                    }

                    // Load notifications from API
                    async function loadNotifications() {
                        try {
                            const res = await fetch('/admin/api/notifications');
                            const data = await res.json();

                            if (data.success && data.notifications.length > 0) {
                                notifBadge.classList.remove('hidden');
                                notifCount.textContent = data.count + ' new';

                                notifList.innerHTML = data.notifications.map(n => `
                                    <a href="${n.link}" 
                                       class="flex items-start gap-3 px-4 py-3 hover:bg-slate-50 transition border-l-2 border-transparent hover:border-brand-500">
                                        <span class="mt-0.5">${getNotifIcon(n.type)}</span>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-xs text-slate-800 font-medium truncate">${n.title}</p>
                                            <p class="text-xs text-slate-500 truncate">${n.subtitle}</p>
                                            <p class="text-xs text-slate-400 mt-1">${timeAgo(n.createdAt)}</p>
                                        </div>
                                    </a>
                                `).join('');
                            } else {
                                notifBadge.classList.add('hidden');
                                notifCount.textContent = '';
                                notifList.innerHTML = `
                                    <div class="px-4 py-6 text-center">
                                        <i class="far fa-bell-slash text-2xl text-slate-300 mb-2"></i>
                                        <p class="text-xs text-slate-400">No new notifications</p>
                                    </div>
                                `;
                            }
                        } catch (error) {
                            console.error('Failed to load notifications:', error);
                            notifList.innerHTML = `
                                <div class="px-4 py-3 text-center text-red-400 text-xs">
                                    <i class="fas fa-exclamation-circle mr-1"></i> Failed to load
                                </div>
                            `;
                        }
                    }

                    // Toggle menu function
                    function toggleMenu(btn, menu, onOpen) {
                        btn.addEventListener('click', (e) => {
                            e.stopPropagation();
                            menu.classList.toggle('hidden');
                            if (!menu.classList.contains('hidden') && onOpen) {
                                onOpen();
                            }
                        });
                    }

                    toggleMenu(notifBtn, notifMenu, loadNotifications);
                    toggleMenu(profileBtn, profileMenu);

                    // Close on click outside
                    document.addEventListener('click', (e) => {
                        if (!notifMenu.contains(e.target) && !notifBtn.contains(e.target)) {
                            notifMenu.classList.add('hidden');
                        }
                        if (!profileMenu.contains(e.target) && !profileBtn.contains(e.target)) {
                            profileMenu.classList.add('hidden');
                        }
                    });

                    // Load notifications on page load
                    loadNotifications();
                </script>