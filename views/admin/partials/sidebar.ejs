<aside class="navigation transition-transform duration-300 transform -translate-x-full md:translate-x-0" id="sidebar">

    <!-- Brand -->
    <div class="brand">
        <a href="/admin/dashboard" class="flex items-center gap-3">
            <img src="/images/logo.jpg" alt="MoRPH Logo">
            <span class="brand-text">
                MoRPH <%= user && user.role==='moderator' ? 'Moderator' : 'Admin' %>
            </span>
        </a>
        <button id="closeSidebar" class="md:hidden ml-auto mr-4 text-slate-400 hover:text-white transition"><i
                class="fas fa-times"></i></button>
    </div>

    <ul class="main-menu">
        <!-- Dashboard -->
        <li class="list <%= locals.path === '/admin/dashboard' || locals.path === '/dashboard' ? 'active' : '' %>">
            <a href="/admin/dashboard">
                <span class="icon"><i class="fas fa-home"></i></span>
                <span class="title">Dashboard</span>
            </a>
        </li>

        <!-- Projects -->
        <li class="list <%= locals.path.startsWith('/projects') ? 'active' : '' %>">
            <a href="/admin/projects">
                <span class="icon"><i class="fas fa-project-diagram"></i></span>
                <span class="title">Projects</span>
            </a>
        </li>

        <!-- Publications -->
        <li class="list <%= locals.path.startsWith('/publications') ? 'active' : '' %>">
            <a href="/admin/publications">
                <span class="icon"><i class="fas fa-book"></i></span>
                <span class="title">Publications</span>
            </a>
        </li>

        <!-- Posts & News -->
        <li
            class="list <%= locals.path === '/admin/posts' || (locals.path.startsWith('/admin/posts') && (!locals.req.query || !locals.req.query.type)) ? 'active' : '' %>">
            <a href="/admin/posts">
                <span class="icon"><i class="fas fa-newspaper"></i></span>
                <span class="title">Posts & News</span>
            </a>
        </li>

        <!-- Training -->
        <li class="list <%= (locals.req.query && locals.req.query.type === 'Training') ? 'active' : '' %>">
            <a href="/admin/posts?type=Training">
                <span class="icon"><i class="fas fa-graduation-cap"></i></span>
                <span class="title">Training</span>
            </a>
        </li>

        <!-- CSR -->
        <li class="list <%= (locals.req.query && locals.req.query.type === 'CSR') ? 'active' : '' %>">
            <a href="/admin/posts?type=CSR">
                <span class="icon"><i class="fas fa-hand-holding-heart"></i></span>
                <span class="title">CSR</span>
            </a>
        </li>

        <!-- Import Facebook -->
        <li class="list <%= locals.path === '/import-facebook' ? 'active' : '' %>">
            <a href="/admin/import-facebook">
                <span class="icon"><i class="fab fa-facebook"></i></span>
                <span class="title">Import Facebook</span>
            </a>
        </li>

        <li class="separator" style="height: 1px; background: #1e293b; margin: 10px 20px;"></li>

        <!-- Team -->
        <li class="list <%= locals.path.startsWith('/team') ? 'active' : '' %>">
            <a href="/admin/team">
                <span class="icon"><i class="fas fa-users"></i></span>
                <span class="title">Team Members</span>
            </a>
        </li>

        <!-- Partners -->
        <li class="list <%= locals.path.startsWith('/partners') ? 'active' : '' %>">
            <a href="/admin/partners">
                <span class="icon"><i class="fas fa-handshake"></i></span>
                <span class="title">Partners</span>
            </a>
        </li>

        <!-- Forms -->
        <li class="list <%= locals.path.startsWith('/forms') ? 'active' : '' %>">
            <a href="/admin/forms">
                <span class="icon"><i class="fas fa-clipboard-list"></i></span>
                <span class="title">Custom Forms</span>
            </a>
        </li>

        <!-- Comments -->
        <li class="list <%= locals.path.startsWith('/comments') ? 'active' : '' %>">
            <a href="/admin/comments">
                <span class="icon"><i class="fas fa-comments"></i></span>
                <span class="title">Comments</span>
            </a>
        </li>

        <% if (locals.enableMailClient) { %>
            <!-- Mail -->
            <li class="list <%= locals.path.startsWith('/mail') ? 'active' : '' %> loading-link">
                <a href="/mail">
                    <span class="icon"><i class="fas fa-envelope-open-text"></i></span>
                    <span class="title">Mail Client</span>
                </a>
            </li>
            <% } %>

                <!-- Media -->
                <li class="list <%= locals.path.startsWith('/media') ? 'active' : '' %>">
                    <a href="/admin/media">
                        <span class="icon"><i class="fas fa-images"></i></span>
                        <span class="title">Media Library</span>
                    </a>
                </li>

                <li class="separator" style="height: 1px; background: #1e293b; margin: 10px 20px;"></li>

                <!-- Settings -->
                <li class="list <%= locals.path.startsWith('/settings') ? 'active' : '' %>">
                    <a href="/admin/settings">
                        <span class="icon"><i class="fas fa-cog"></i></span>
                        <span class="title">Settings</span>
                    </a>
                </li>

                <% if (locals.user && locals.user.role==='admin' ) { %>
                    <!-- Users -->
                    <li class="list <%= locals.path.startsWith('/users') ? 'active' : '' %>">
                        <a href="/admin/users">
                            <span class="icon"><i class="fas fa-user-shield"></i></span>
                            <span class="title">Users & Roles</span>
                        </a>
                    </li>
                    <% } %>
    </ul>

    <!-- Profile Section -->
    <ul class="profile-wrapper">
        <li class="list">
            <a href="/admin/logout">
                <span class="icon"><i class="fas fa-sign-out-alt"></i></span>
                <span class="title">Logout</span>
            </a>
        </li>
    </ul>
</aside>

<!-- Mobile Sidebar Overlay -->
<div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-40 hidden md:hidden"></div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const sidebar = document.getElementById('sidebar');
        const openBtn = document.getElementById('openSidebar');
        const closeBtn = document.getElementById('closeSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const mainContent = document.getElementById('main-content');

        // --- Mobile Logic ---
        function openSidebar() {
            sidebar.classList.remove('-translate-x-full');
            sidebar.classList.add('translate-x-0');
            overlay.classList.remove('hidden');
            document.body.style.overflow = 'hidden';

            // Force expand width on mobile
            if (window.innerWidth < 768) {
                sidebar.style.width = '300px';
            }
        }

        function closeSidebar() {
            sidebar.classList.add('-translate-x-full');
            sidebar.classList.remove('translate-x-0');
            overlay.classList.add('hidden');
            document.body.style.overflow = '';
            sidebar.style.width = '';
        }

        if (openBtn) openBtn.addEventListener('click', openSidebar);
        if (closeBtn) closeBtn.addEventListener('click', closeSidebar);
        if (overlay) overlay.addEventListener('click', closeSidebar);

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && sidebar.classList.contains('translate-x-0')) {
                closeSidebar();
            }
        });

        // --- Desktop Push Content Logic ---
        // Push content when hovering specifically on desktop
        if (mainContent) {
            // Match the transition speed of the sidebar (0.5s) for smoothness
            mainContent.style.transition = 'margin-left 0.5s ease-in-out, width 0.5s ease-in-out';

            sidebar.addEventListener('mouseenter', () => {
                if (window.innerWidth >= 768) {
                    mainContent.style.marginLeft = '300px';
                }
            });

            sidebar.addEventListener('mouseleave', () => {
                if (window.innerWidth >= 768) {
                    mainContent.style.marginLeft = '80px';
                }
            });
        }
    });
</script>