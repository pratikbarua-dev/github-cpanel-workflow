            <i
                class="fas fa-project-diagram w-5 text-center <%= path.startsWith('/projects') ? 'text-white' : 'text-slate-400 group-hover:text-white' %>"></i>
            Projects
        </a>

        <a href="/admin/publications"
            class="group flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 <%= path.startsWith('/publications') ? 'bg-brand-600 text-white shadow-lg shadow-brand-600/20' : 'hover:bg-slate-800 hover:text-white' %>">
            <i
                class="fas fa-book w-5 text-center <%= path.startsWith('/publications') ? 'text-white' : 'text-slate-400 group-hover:text-white' %>"></i>
            Publications
        </a>

        <a href="/admin/posts"
            class="group flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 <%= path.startsWith('/posts') ? 'bg-brand-600 text-white shadow-lg shadow-brand-600/20' : 'hover:bg-slate-800 hover:text-white' %>">
            <i
                class="fas fa-newspaper w-5 text-center <%= path.startsWith('/posts') ? 'text-white' : 'text-slate-400 group-hover:text-white' %>"></i>
            Posts & News
        </a>

        <a href="/admin/import-facebook"
            class="group flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 <%= path === '/import-facebook' ? 'bg-brand-600 text-white shadow-lg shadow-brand-600/20' : 'hover:bg-slate-800 hover:text-white' %>">
            <i
                class="fab fa-facebook w-5 text-center <%= path === '/import-facebook' ? 'text-white' : 'text-slate-400 group-hover:text-white' %>"></i>
            Import from Facebook
        </a>

        <p class="px-4 text-xs font-semibold text-slate-500 uppercase tracking-wider mt-6 mb-2">Management</p>

        <a href="/admin/team"
            class="group flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 <%= path.startsWith('/team') ? 'bg-brand-600 text-white shadow-lg shadow-brand-600/20' : 'hover:bg-slate-800 hover:text-white' %>">
