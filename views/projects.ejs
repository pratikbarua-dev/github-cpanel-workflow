<%- include('partials/header') %>

    <!-- Hero Section -->
    <section class="bg-secondary text-white py-20 relative overflow-hidden">
        <div
            class="absolute top-0 left-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1600&q=40')] bg-cover bg-center opacity-10">
        </div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h1 class="text-4xl md:text-5xl font-bold mb-4">Research Projects</h1>
            <p class="text-xl text-teal-100 max-w-2xl mx-auto">Innovative studies driving policy and social change.</p>
        </div>
    </section>

    <!-- Projects Grid -->
    <section class="py-20 bg-white">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% if (projects.length> 0) { %>
                    <% projects.forEach(function(project) { %>
                        <div
                            class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-100 group reveal">
                            <div class="relative h-48 overflow-hidden">
                                <img src="<%= project.image_url %>"
                                    class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500">
                                <div
                                    class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-primary">
                                    <%= project.status %>
                                </div>
                            </div>
                            <div class="p-6">
                                <h3
                                    class="text-xl font-bold text-secondary mb-2 group-hover:text-primary transition-colors">
                                    <%= locale==='bn' && project.title_bn ? project.title_bn : project.title %>
                                </h3>
                                <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                                    <%= locale==='bn' && project.summary_bn ? project.summary_bn : project.summary %>
                                </p>
                                <a href="/projects/<%= project.slug %>"
                                    class="inline-flex items-center text-primary font-semibold text-sm hover:gap-2 transition-all">
                                    <%= __('home.view_details') %> <i class="fas fa-arrow-right ml-1"></i>
                                </a>
                            </div>
                        </div>
                        <% }); %>
                            <% } else { %>
                                <div class="col-span-full text-center py-10">
                                    <p class="text-gray-500 text-lg">No projects found at the moment.</p>
                                </div>
                                <% } %>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>