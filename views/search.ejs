<%- include('partials/header', { title: 'Search Results - MoRPH' }) %>

    <main class="flex-grow bg-gray-50">
        <div class="container mx-auto px-4 py-16">
            <h1 class="text-3xl font-bold text-secondary mb-8">Search Results for "<%= query %>"</h1>

            <% if (projects.length===0 && publications.length===0 && posts.length===0) { %>
                <div class="text-center py-20 bg-white rounded-xl shadow-sm">
                    <div class="text-6xl text-gray-200 mb-4"><i class="fas fa-search"></i></div>
                    <h3 class="text-xl font-bold text-gray-400">No results found</h3>
                    <p class="text-gray-500 mt-2">Try adjusting your search terms.</p>
                    <div class="mt-8">
                        <form action="/search" method="GET" class="flex justify-center max-w-md mx-auto">
                            <input type="text" name="q" placeholder="Search again..."
                                class="w-full px-4 py-2 border border-gray-300 rounded-l-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                            <button type="submit"
                                class="bg-primary text-white px-6 py-2 rounded-r-lg hover:bg-teal-700 transition">Search</button>
                        </form>
                    </div>
                </div>
                <% } else { %>

                    <% if (projects.length> 0) { %>
                        <h2 class="text-2xl font-bold text-teal-700 mb-6 border-b border-gray-200 pb-2">Projects</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
                            <% projects.forEach(function(project) { %>
                                <a href="/projects/<%= project.slug %>" class="block group">
                                    <article
                                        class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all h-full flex flex-col overflow-hidden">
                                        <div class="h-48 overflow-hidden">
                                            <img src="<%= project.image_url %>" alt="<%= project.title %>"
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                        </div>
                                        <div class="p-6 flex-1">
                                            <h3
                                                class="text-lg font-bold text-gray-800 mb-2 group-hover:text-primary transition-colors">
                                                <%= project.title %>
                                            </h3>
                                            <p class="text-gray-600 text-sm line-clamp-3">
                                                <%= project.summary %>
                                            </p>
                                        </div>
                                    </article>
                                </a>
                                <% }); %>
                        </div>
        </div>
        <% } %>

            <% if (posts.length> 0) { %>
                <h2 class="text-2xl font-bold text-teal-700 mb-6 border-b border-gray-200 pb-2">News & Articles</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
                    <% posts.forEach(function(post) { %>
                        <a href="/news/<%= post.slug %>" class="block group">
                            <article
                                class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all h-full flex flex-col overflow-hidden">
                                <div class="p-6 flex-1">
                                    <div class="flex items-center gap-2 mb-2">
                                        <span
                                            class="text-xs font-semibold px-2 py-1 bg-teal-100 text-teal-700 rounded-full">
                                            <%= post.type %>
                                        </span>
                                        <span class="text-xs text-gray-500">
                                            <%= post.date %>
                                        </span>
                                    </div>
                                    <h3
                                        class="text-lg font-bold text-gray-800 mb-2 group-hover:text-primary transition-colors">
                                        <%= post.title %>
                                    </h3>
                                    <p class="text-gray-600 text-sm line-clamp-3">
                                        <%= post.excerpt || 'No excerpt available.' %>
                                    </p>
                                </div>
                            </article>
                        </a>
                        <% }); %>
                </div>
                <% } %>

                    <% if (publications.length> 0) { %>
                        <h2 class="text-2xl font-bold text-teal-700 mb-6 border-b border-gray-200 pb-2">
                            Publications</h2>
                        <div class="space-y-4 mb-16">
                            <% publications.forEach(function(pub) { %>
                                <div
                                    class="bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition-all flex items-start gap-4">
                                    <div class="bg-teal-50 text-teal-600 p-3 rounded-lg text-xl">
                                        <i class="fas fa-file-alt"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800 mb-1">
                                            <%= pub.title %>
                                        </h3>
                                        <p class="text-sm text-gray-500 mb-2">
                                            <%= pub.category %> • <%= pub.published_date %>
                                        </p>
                                        <% if (pub.file_url) { %>
                                            <a href="<%= pub.file_url %>"
                                                class="text-sm text-primary font-semibold hover:underline"
                                                target="_blank">Download PDF</a>
                                            <% } %>
                                    </div>
                                </div>
                                <% }); %>
                        </div>
                        <% } %>

                            <% } %>
                                </div>
    </main>

    <%- include('partials/footer') %>