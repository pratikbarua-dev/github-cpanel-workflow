<%- include('partials/header') %>

    <!-- Hero Section -->
    <section class="pt-32 pb-20 bg-gradient-to-br from-teal-50/50 via-white to-white relative overflow-hidden">
        <div
            class="absolute top-0 right-0 w-1/2 h-full bg-teal-50/20 blur-3xl rounded-full -translate-y-1/2 translate-x-1/4">
        </div>

        <div class="container mx-auto px-4 relative z-10 text-center">
            <h1 class="text-4xl md:text-5xl font-bold text-secondary mb-6">
                Get <span class="text-primary">Involved</span>
            </h1>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
                Be part of the change. Join us in shaping a sustainable future through action and collaboration.
            </p>
        </div>
    </section>

    <!-- Engagement Cards -->
    <section class="py-16 md:py-24 bg-white relative">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto -mt-32">

                <!-- Card 1: Collaborate -->
                <div
                    class="bg-white p-8 rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.08)] hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] transition-all duration-300 transform hover:-translate-y-1 border border-gray-50 flex flex-col items-center text-center group">
                    <div class="w-20 h-20 mb-6 relative">
                        <div
                            class="absolute inset-0 bg-teal-50 rounded-full scale-0 group-hover:scale-110 transition-transform duration-500">
                        </div>
                        <i class="fas fa-handshake text-4xl text-primary relative z-10 leading-[5rem]"></i>
                    </div>
                    <h3 class="text-xl font-bold text-secondary mb-3 group-hover:text-primary transition-colors">
                        Collaborate on Research</h3>
                    <p class="text-gray-600 text-sm mb-8 leading-relaxed">
                        Partner with us on applied research, policy analysis, and community interventions. We
                        collaborate with universities, NGOs, and UN agencies to drive evidence-based solutions.
                    </p>
                    <a href="/contact?subject=Research Collaboration"
                        class="mt-auto btn-primary w-full py-3 rounded-lg text-sm font-semibold shadow-lg shadow-teal-500/20 hover:shadow-teal-500/30">
                        Learn More
                    </a>
                </div>

                <!-- Card 2: Careers -->
                <div
                    class="bg-white p-8 rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.08)] hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] transition-all duration-300 transform hover:-translate-y-1 border border-gray-50 flex flex-col items-center text-center group">
                    <div class="w-20 h-20 mb-6 relative">
                        <div
                            class="absolute inset-0 bg-teal-50 rounded-full scale-0 group-hover:scale-110 transition-transform duration-500">
                        </div>
                        <i class="fas fa-briefcase text-4xl text-primary relative z-10 leading-[5rem]"></i>
                    </div>
                    <h3 class="text-xl font-bold text-secondary mb-3 group-hover:text-primary transition-colors">
                        Careers</h3>
                    <p class="text-gray-600 text-sm mb-8 leading-relaxed">
                        Join our team of dedicated researchers, policy analysts, and operations specialists.
                    </p>
                    <a href="/apply?type=career"
                        class="mt-auto btn-primary w-full py-3 rounded-lg text-sm font-semibold shadow-lg shadow-teal-500/20 hover:shadow-teal-500/30">
                        View Openings
                    </a>
                </div>

                <!-- Card 3: Volunteer -->
                <div
                    class="bg-white p-8 rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.08)] hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] transition-all duration-300 transform hover:-translate-y-1 border border-gray-50 flex flex-col items-center text-center group">
                    <div class="w-20 h-20 mb-6 relative">
                        <div
                            class="absolute inset-0 bg-teal-50 rounded-full scale-0 group-hover:scale-110 transition-transform duration-500">
                        </div>
                        <i class="fas fa-hands-helping text-4xl text-primary relative z-10 leading-[5rem]"></i>
                    </div>
                    <h3 class="text-xl font-bold text-secondary mb-3 group-hover:text-primary transition-colors">
                        Volunteer</h3>
                    <p class="text-gray-600 text-sm mb-8 leading-relaxed">
                        Contribute your time and skills to our community initiatives and field research projects.
                    </p>
                    <a href="/apply?type=volunteer"
                        class="mt-auto btn-primary w-full py-3 rounded-lg text-sm font-semibold shadow-lg shadow-teal-500/20 hover:shadow-teal-500/30">
                        Apply to Volunteer
                    </a>
                </div>



            </div>
        </div>
    </section>

    <%- include('partials/footer') %>