<%- include('partials/header', { title: 'Partnerships - MoRPH' }) %>

    <main class="flex-grow">
        <!-- Hero Section -->
        <section class="bg-gradient-to-br from-secondary to-footer text-white py-20 relative overflow-hidden">
            <div
                class="absolute top-0 left-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1600&q=40')] bg-cover bg-center opacity-10">
            </div>
            <div class="container mx-auto px-4 relative z-10 text-center">
                <h1 class="text-4xl md:text-5xl font-bold mb-4">Our Partnerships</h1>
                <p class="text-xl text-teal-100 max-w-2xl mx-auto">Collaborating with global institutions to drive
                    impact.</p>
            </div>
        </section>

        <!-- Partners Grid -->
        <section class="py-20 bg-white">
            <div class="container mx-auto px-4">
                <div class="text-center max-w-3xl mx-auto mb-16 reveal">
                    <p class="text-gray-600 leading-relaxed text-lg">
                        MoRPH believes that complex global challenges cannot be solved in isolation. We partner with
                        universities, NGOs, and research labs worldwide to pool resources and expertise.
                    </p>
                </div>

                <h2 class="text-2xl font-bold text-center text-gray-400 mb-10 uppercase tracking-widest">Collaborations
                    & Networks</h2>

                <!-- Academic Partners -->
                <div class="mb-16">
                    <h3
                        class="text-xl font-bold text-secondary text-center mb-8 border-b border-gray-100 pb-4 mx-auto max-w-xs">
                        Academic Partners</h3>
                    <div class="flex flex-wrap justify-center gap-8 md:gap-12">
                        <div class="flex flex-col items-center group w-48">
                            <div
                                class="w-48 h-32 bg-white rounded-lg shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="/images/partners/mbstu.png" alt="MBSTU"
                                    class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">Mawlana Bhashani
                                Science and Technology University</span>
                        </div>
                        <div class="flex flex-col items-center group w-48">
                            <div
                                class="w-48 h-32 bg-white rounded-lg shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="/images/partners/diu.png" alt="Daffodil International University"
                                    class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">Daffodil
                                International University</span>
                        </div>
                    </div>
                </div>

                <!-- Global & National Networks -->
                <div class="mb-16">
                    <h3
                        class="text-xl font-bold text-secondary text-center mb-8 border-b border-gray-100 pb-4 mx-auto max-w-xs">
                        Networks & Forums</h3>
                    <div class="flex flex-wrap justify-center gap-8 md:gap-12">
                        <!-- GFMG Image -->
                        <div class="flex flex-col items-center group w-48">
                            <div
                                class="w-48 h-28 bg-white rounded-lg shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="/images/partners/gfmd_logo.png"
                                    alt="Grassroots Forum for Migration Governance"
                                    class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">Grassroots Forum
                                for
                                Migration Governance</span>
                        </div>

                        <div class="flex flex-col items-center group w-48">
                            <div
                                class="w-48 h-28 bg-white rounded-lg shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="https://placehold.co/300x150/white/2c3e50?text=GFMD" alt="GFMD"
                                    class="max-h-full max-w-full object-contain grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">Global Forum on
                                Migration and Development</span>
                        </div>

                        <div class="flex flex-col items-center group w-48">
                            <div
                                class="w-48 h-28 bg-white rounded-lg shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="/images/partners/bcsm.png" alt="BCSM"
                                    class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">Bangladesh Civil
                                Society for Migrants</span>
                        </div>

                        <div class="flex flex-col items-center group w-48">
                            <div
                                class="w-48 h-28 bg-white rounded-lg shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="/images/partners/mfa.png" alt="To MFA"
                                    class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">Migrants Forum in
                                Asia</span>
                        </div>
                    </div>
                </div>

                <!-- UN & Government -->
                <div class="mb-12">
                    <h2 class="text-2xl font-bold text-center text-gray-400 mb-10 uppercase tracking-widest">Liaison
                        with UN & Government</h2>
                    <div class="flex flex-wrap justify-center gap-8 md:gap-14">
                        <div class="flex flex-col items-center group w-32">
                            <div
                                class="w-32 h-32 bg-white rounded-full shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="/images/partners/govt_bd.png" alt="Govt. of Bangladesh"
                                    class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">Government of
                                Bangladesh</span>
                        </div>

                        <div class="flex flex-col items-center group w-32">
                            <div
                                class="w-32 h-32 bg-white rounded-full shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="/images/partners/iom.png" alt="IOM"
                                    class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">IOM</span>
                        </div>

                        <div class="flex flex-col items-center group w-32">
                            <div
                                class="w-32 h-32 bg-white rounded-full shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="/images/partners/unhcr.png" alt="UNHCR"
                                    class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">UNHCR</span>
                        </div>

                        <div class="flex flex-col items-center group w-32">
                            <div
                                class="w-32 h-32 bg-white rounded-full shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="/images/partners/who.png" alt="WHO"
                                    class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">WHO</span>
                        </div>

                        <div class="flex flex-col items-center group w-32">
                            <div
                                class="w-32 h-32 bg-white rounded-full shadow-sm border border-gray-100 flex items-center justify-center p-4 hover:shadow-md transition mb-3">
                                <img src="/images/partners/wfp.png" alt="WFP"
                                    class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform">
                            </div>
                            <span class="text-sm text-gray-600 text-center font-medium leading-tight">WFP</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="py-20 bg-teal-50">
            <div class="container mx-auto px-4 text-center">
                <h2 class="text-3xl font-bold text-secondary mb-6">Interested in Collaborating?</h2>
                <p class="text-gray-600 mb-8 max-w-xl mx-auto">We are always looking for new partners to advance our
                    mission. Contact us to explore opportunities.</p>
                <a href="/contact" class="btn-primary">Become a Partner</a>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>