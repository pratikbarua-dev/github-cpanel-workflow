<%- include('partials/header', { title: 'Apply - Get Involved' }) %>

    <main class="flex-grow bg-gray-50">
        <section class="py-16">
            <div class="container mx-auto px-4 max-w-2xl">
                <div class="text-center mb-10">
                    <h1 class="text-3xl font-bold text-secondary mb-4">Submit Your Application</h1>
                    <p class="text-gray-600">We are excited to have you join our mission. Please complete the form
                        below.</p>
                </div>

                <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
                    <form action="/apply" method="POST" enctype="multipart/form-data" class="space-y-6">

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-2">Full Name</label>
                                <input type="text" name="name" required
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-teal-500 focus:ring-1 focus:ring-teal-500 transition-colors">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-2">Email Address</label>
                                <input type="email" name="email" required
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-teal-500 focus:ring-1 focus:ring-teal-500 transition-colors">
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">Application Type</label>
                            <select name="type"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-teal-500 focus:ring-1 focus:ring-teal-500 bg-white">
                                <% applicationTypes.forEach(type => { %>
                                    <option value="<%= type %>"><%= type %></option>
                                <% }); %>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">Message / Cover Letter</label>
                            <textarea name="message" rows="5" required
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-teal-500 focus:ring-1 focus:ring-teal-500 transition-colors"></textarea>
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">Upload CV / Proposal
                                (PDF/Doc)</label>
                            <div
                                class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:bg-gray-50 transition-colors cursor-pointer relative">
                                <input type="file" name="file"
                                    class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
                                    onchange="document.getElementById('file-name').textContent = this.files[0]?.name || 'Choose a file'">
                                <div class="text-gray-500">
                                    <i class="fas fa-cloud-upload-alt text-3xl mb-2 text-gray-400"></i>
                                    <p class="text-sm font-medium">Click to upload or drag and drop</p>
                                    <p class="text-xs mt-1 text-gray-400">Max size 10MB</p>
                                    <p id="file-name" class="text-sm text-teal-600 font-semibold mt-2"></p>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">Security Check</label>
                            <div class="flex items-center gap-4">
                                <div class="bg-gray-100 p-2 rounded-lg border border-gray-300">
                                    <img src="/captcha" alt="CAPTCHA" class="h-12 rounded cursor-pointer"
                                        onclick="this.src='/captcha?'+Math.random()" title="Click to refresh">
                                </div>
                                <input type="text" name="captcha" placeholder="Enter code" required
                                    class="flex-grow px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-teal-500 focus:ring-1 focus:ring-teal-500 transition-colors">
                            </div>
                        </div>

                        <button type="submit" class="w-full btn-primary py-4 text-lg shadow-lg">Submit
                            Application</button>

                    </form>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>