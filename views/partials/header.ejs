<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title || 'MoRPH - Advancing Research & Innovation' %>
    </title>
    <meta name="description"
        content="MoRPH - Advancing Research & Innovation. An independent think tank based in Bangladesh working across public health, migration, refugee studies, environment, and ICT.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/jpeg" href="/images/logo.jpg">

    <!-- Google Fonts (Non-blocking) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet"
        media="print" onload="this.media='all'">
    <noscript>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    </noscript>

    <!-- FontAwesome (Non-blocking) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
        media="print" onload="this.media='all'">
    <noscript>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    </noscript>

    <!-- Main Stylesheet -->
    <link href="/styles.css" rel="stylesheet">
</head>

<body class="font-sans text-gray-800 antialiased flex flex-col min-h-screen" style="background-color: #f9f1f1;">

    <header class="bg-white sticky top-0 z-50 shadow-sm py-4">
        <div class="container mx-auto px-4 flex justify-between items-center">
            <a href="/" class="flex items-center gap-2 text-2xl font-bold text-primary group">
                <img src="/images/logo.jpg" alt="MoRPH Logo" class="h-10 md:h-12 w-auto object-contain">
                <span style="color: #B91C1C;">MoRPH</span>
            </a>

            <nav class="hidden lg:flex items-center gap-6">
                <a href="/" class="nav-link">
                    <%= __('header.home') %>
                </a>

                <!-- Training -->
                <a href="/training" class="nav-link <%= (locals.path === '/training') ? 'active' : '' %>">
                    <%= __('header.training') %>
                </a>

                <!-- CSR Dropdown -->
                <div class="relative group">
                    <button class="nav-link flex items-center gap-1 group-hover:text-primary focus:outline-none">
                        <%= __('header.csr') %> <i
                                class="fas fa-chevron-down text-xs opacity-75 transition-transform group-hover:rotate-180"></i>
                    </button>
                    <div
                        class="absolute left-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2 z-50">
                        <% if (locals.csrSections && csrSections.length> 0) { %>
                            <% csrSections.forEach(section=> { %>
                                <a href="/csr/<%= section.toLowerCase().replace(/ /g, '-') %>"
                                    class="block px-5 py-3 text-secondary hover:bg-teal-50 hover:text-primary first:rounded-t-xl transition-colors">
                                    <%= section %>
                                </a>
                                <% }); %>
                                    <% } else { %>
                                        <a href="/csr"
                                            class="block px-5 py-3 text-secondary hover:bg-teal-50 hover:text-primary first:rounded-t-xl transition-colors">
                                            General
                                        </a>
                                        <% } %>
                    </div>
                </div>

                <!-- About Dropdown -->
                <div class="relative group">
                    <button class="nav-link flex items-center gap-1 group-hover:text-primary focus:outline-none">
                        <%= __('header.about') %> <i
                                class="fas fa-chevron-down text-xs opacity-75 transition-transform group-hover:rotate-180"></i>
                    </button>
                    <div
                        class="absolute left-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2 z-50">
                        <a href="/about"
                            class="block px-5 py-3 text-secondary hover:bg-teal-50 hover:text-primary first:rounded-t-xl transition-colors">
                            <%= __('header.who_we_are') %>
                        </a>
                        <a href="/team"
                            class="block px-5 py-3 text-secondary hover:bg-teal-50 hover:text-primary transition-colors">
                            <%= __('header.team') %>
                        </a>
                        <a href="/partnerships"
                            class="block px-5 py-3 text-secondary hover:bg-teal-50 hover:text-primary last:rounded-b-xl border-t border-gray-50 transition-colors">
                            <%= __('header.partnerships') %>
                        </a>
                    </div>
                </div>

                <!-- Research Dropdown -->
                <div class="relative group">
                    <button class="nav-link flex items-center gap-1 group-hover:text-primary focus:outline-none">
                        <%= __('header.research') %> <i
                                class="fas fa-chevron-down text-xs opacity-75 transition-transform group-hover:rotate-180"></i>
                    </button>
                    <div
                        class="absolute left-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2 z-50">
                        <a href="/projects"
                            class="block px-5 py-3 text-secondary hover:bg-teal-50 hover:text-primary transition-colors">
                            <%= __('header.projects') %>
                        </a>
                        <a href="/publications"
                            class="block px-5 py-3 text-secondary hover:bg-teal-50 hover:text-primary last:rounded-b-xl border-t border-gray-50 transition-colors">
                            <%= __('header.publications') %>
                        </a>
                    </div>
                </div>

                <a href="/focus-areas" class="nav-link">
                    <%= __('header.focus_areas') %>
                </a>
                <a href="/contact" class="nav-link">
                    <%= __('header.contact') %>
                </a>
            </nav>

            <div class="hidden lg:flex items-center gap-3">
                <form action="/search" method="GET" class="relative group">
                    <input type="text" name="q" placeholder="<%= __('header.search_placeholder') %>"
                        class="pl-4 pr-10 py-2 rounded-full border border-gray-200 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 text-sm w-32 focus:w-48 transition-all duration-300 outline-none">
                    <button type="submit"
                        class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-teal-600">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
                <div class="text-sm font-medium flex items-center gap-1 text-gray-400">
                    <a href="?lang=en"
                        class="<%= locale === 'en' ? 'text-primary font-bold' : 'hover:text-primary transition' %>">EN</a>
                    <span>/</span>
                    <a href="?lang=bn"
                        class="<%= locale === 'bn' ? 'text-primary font-bold' : 'hover:text-primary transition' %>">BN</a>
                </div>
                <a href="/partner-with-us" class="btn-primary group">
                    <span class="relative z-10">
                        <%= __('header.partner_with_us') %>
                    </span>
                </a>
            </div>

            <button id="mobile-menu-btn" class="lg:hidden text-2xl text-secondary p-2 focus:outline-none">
                <i class="fas fa-bars"></i>
            </button>
        </div>

        <!-- Mobile Menu (Full Overlay) -->
        <div id="mobile-menu" class="hidden fixed inset-0 z-[60] bg-white overflow-y-auto lg:hidden">
            <div class="container mx-auto px-4 py-4 flex flex-col min-h-screen">
                <div class="flex justify-between items-center mb-8">
                    <a href="/" class="flex items-center gap-2 text-2xl font-bold text-primary">
                        <img src="/images/logo.jpg" alt="MoRPH Logo" class="h-10 w-auto object-contain">
                        <span style="color: #B91C1C;">MoRPH</span>
                    </a>
                    <button id="close-mobile-menu" class="text-2xl text-secondary p-2 focus:outline-none">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <!-- Search Mobile -->
                <form action="/search" method="GET" class="mb-6 relative">
                    <input type="text" name="q" placeholder="<%= __('header.search_placeholder') %>"
                        class="w-full pl-4 pr-10 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-gray-50">
                    <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">
                        <i class="fas fa-search"></i>
                    </button>
                </form>

                <nav class="flex flex-col space-y-2 flex-grow">
                    <a href="/"
                        class="block px-4 py-3 text-lg font-medium text-secondary hover:bg-gray-50 rounded-xl transition-colors">
                        <%= __('header.home') %>
                    </a>

                    <!-- Training -->
                    <a href="/training"
                        class="block px-4 py-3 text-lg font-medium text-secondary hover:bg-gray-50 rounded-xl transition-colors">
                        <%= __('header.training') %>
                    </a>

                    <!-- CSR Accordion -->
                    <div class="mobile-dropdown group border-b border-gray-50">
                        <button
                            class="w-full flex justify-between items-center px-4 py-3 text-lg font-medium text-secondary hover:bg-gray-50 rounded-xl transition-colors mobile-dropdown-btn">
                            <%= __('header.csr') %> <i
                                    class="fas fa-chevron-down text-sm transition-transform duration-300"></i>
                        </button>
                        <div class="hidden pl-4 space-y-1 mb-2 mobile-dropdown-content">
                            <% if (locals.csrSections && csrSections.length> 0) { %>
                                <% csrSections.forEach(section=> { %>
                                    <a href="/csr/<%= section.toLowerCase().replace(/ /g, '-') %>"
                                        class="block px-4 py-2 text-gray-600 hover:text-primary rounded-lg transition-colors">
                                        <%= section %>
                                    </a>
                                    <% }); %>
                                        <% } else { %>
                                            <a href="/csr"
                                                class="block px-4 py-2 text-gray-600 hover:text-primary rounded-lg transition-colors">
                                                General
                                            </a>
                                            <% } %>
                        </div>
                    </div>

                    <!-- About Accordion -->
                    <div class="mobile-dropdown group border-b border-gray-50">
                        <button
                            class="w-full flex justify-between items-center px-4 py-3 text-lg font-medium text-secondary hover:bg-gray-50 rounded-xl transition-colors mobile-dropdown-btn">
                            <%= __('header.about') %> <i
                                    class="fas fa-chevron-down text-sm transition-transform duration-300"></i>
                        </button>
                        <div class="hidden pl-4 space-y-1 mb-2 mobile-dropdown-content">
                            <a href="/about"
                                class="block px-4 py-2 text-gray-600 hover:text-primary rounded-lg transition-colors">
                                <%= __('header.who_we_are') %>
                            </a>
                            <a href="/team"
                                class="block px-4 py-2 text-gray-600 hover:text-primary rounded-lg transition-colors">
                                <%= __('header.team') %>
                            </a>
                            <a href="/partnerships"
                                class="block px-4 py-2 text-gray-600 hover:text-primary rounded-lg transition-colors">
                                <%= __('header.partnerships') %>
                            </a>
                        </div>
                    </div>

                    <!-- Research Accordion -->
                    <div class="mobile-dropdown group border-b border-gray-50">
                        <button
                            class="w-full flex justify-between items-center px-4 py-3 text-lg font-medium text-secondary hover:bg-gray-50 rounded-xl transition-colors mobile-dropdown-btn">
                            <%= __('header.research') %> <i
                                    class="fas fa-chevron-down text-sm transition-transform duration-300"></i>
                        </button>
                        <div class="hidden pl-4 space-y-1 mb-2 mobile-dropdown-content">
                            <a href="/projects"
                                class="block px-4 py-2 text-gray-600 hover:text-primary rounded-lg transition-colors">
                                <%= __('header.projects') %>
                            </a>
                            <a href="/publications"
                                class="block px-4 py-2 text-gray-600 hover:text-primary rounded-lg transition-colors">
                                <%= __('header.publications') %>
                            </a>
                        </div>
                    </div>

                    <a href="/focus-areas"
                        class="block px-4 py-3 text-lg font-medium text-secondary hover:bg-gray-50 rounded-xl transition-colors">
                        <%= __('header.focus_areas') %>
                    </a>
                    <a href="/contact"
                        class="block px-4 py-3 text-lg font-medium text-secondary hover:bg-gray-50 rounded-xl transition-colors">
                        <%= __('header.contact') %>
                    </a>
                </nav>

                <div class="mt-8 pb-8 space-y-4">
                    <a href="/partner-with-us"
                        class="block w-full text-center bg-gradient-to-r from-primary to-primary-light text-white px-6 py-4 rounded-xl font-bold text-lg shadow-md">
                        <%= __('header.partner_with_us') %>
                    </a>

                    <div class="flex justify-center gap-4 text-sm font-medium text-gray-500">
                        <a href="?lang=en" class="<%= locale === 'en' ? 'text-primary font-bold' : '' %>">English</a>
                        <span>|</span>
                        <a href="?lang=bn" class="<%= locale === 'bn' ? 'text-primary font-bold' : '' %>">বাংলা</a>
                    </div>
                </div>
            </div>
        </div>
    </header>
    <main class="flex-grow">