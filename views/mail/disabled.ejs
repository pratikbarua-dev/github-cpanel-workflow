<%- include('../admin/partials/header', { title: 'Morph Mail' , path: '/mail' }) %>

    <div class="flex flex-col h-screen bg-slate-50 relative overflow-hidden">
        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col items-center justify-center p-6 ml-64 mt-16">

            <div
                class="bg-white rounded-2xl shadow-xl p-12 max-w-lg w-full text-center border border-slate-100 relative overflow-hidden group">

                <!-- Decorative Background Elements -->
                <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-slate-300 to-slate-400"></div>
                <div class="absolute -bottom-12 -right-12 w-32 h-32 bg-slate-50 rounded-full blur-2xl opacity-50"></div>
                <div class="absolute -top-12 -left-12 w-32 h-32 bg-slate-100 rounded-full blur-2xl opacity-50"></div>

                <!-- Icon -->
                <div class="mb-8 relative inline-block">
                    <div
                        class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mx-auto shadow-inner mb-4">
                        <i
                            class="fas fa-envelope-open-text text-5xl text-slate-300 group-hover:text-brand-500 transition-colors duration-500"></i>
                    </div>
                    <div
                        class="absolute -top-2 -right-2 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-md border border-slate-100">
                        <i class="fas fa-lock text-slate-400 text-sm"></i>
                    </div>
                </div>

                <!-- Text Content -->
                <h2 class="text-2xl font-bold text-slate-800 mb-3 tracking-tight">Mail Client Not Subscribed</h2>
                <p class="text-slate-500 mb-8 leading-relaxed">
                    This feature is currently disabled. To access the integrated mail client, please contact your system
                    administrator to enable the <code
                        class="bg-slate-100 px-2 py-1 rounded text-slate-600 text-sm font-mono">Mail Module</code>.
                </p>

                <!-- Action Button -->
                <a href="/admin/dashboard"
                    class="inline-flex items-center gap-2 px-6 py-3 bg-white border border-slate-200 text-slate-700 font-medium rounded-xl hover:bg-slate-50 hover:border-slate-300 hover:text-slate-900 transition-all duration-200 shadow-sm hover:shadow-md">
                    <i class="fas fa-arrow-left text-sm"></i>
                    <span>Back to Dashboard</span>
                </a>

            </div>

            <!-- Footer Help -->
            <div class="mt-8 text-slate-400 text-sm">
                Need help? <a href="#"
                    class="text-slate-500 hover:text-slate-700 underline decoration-slate-300 underline-offset-2">View
                    Documentation</a>
            </div>

        </div>
    </div>

    <%- include('../admin/partials/footer') %>