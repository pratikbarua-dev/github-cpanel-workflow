<%- include('partials/header', { title: 'Who We Are - MoRPH' }) %>

    <main class="flex-grow">
        <!-- Hero Section -->
        <section class="bg-gradient-to-br from-secondary to-footer text-white py-20 relative overflow-hidden">
            <div
                class="absolute top-0 left-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1600&q=40')] bg-cover bg-center opacity-10">
            </div>
            <div class="container mx-auto px-4 relative z-10 text-center">
                <h1 class="text-4xl md:text-5xl font-bold mb-4">About MoRPH</h1>
                <p class="text-xl text-teal-100 max-w-2xl mx-auto">Bridging scientific research with traditional wisdom
                    for a sustainable future.</p>
            </div>
        </section>

        <!-- Who We Are / Profile -->
        <section class="py-16 bg-white">
            <div class="container mx-auto px-4">
                <div class="max-w-4xl mx-auto text-lg text-gray-700 leading-relaxed space-y-6">
                    <p>
                        <strong class="text-secondary text-xl">Moulovibari Research and Partnership Hub (MoRPH)</strong>
                        is a grassroots think tank dedicated to advancing knowledge, innovation, and solutions in areas
                        critical to society and sustainable development. Based in Bangladesh, MoRPH works across diverse
                        fields including public health, migration, refugee studies, environment, climate change, ICT,
                        language, and Bangladesh studies.
                    </p>
                    <p>
                        Founded on the belief that local voices and grassroots perspectives are essential for meaningful
                        change, MoRPH bridges the gap between research, policy, and practice. The Hub fosters
                        collaboration among academics, practitioners, policymakers, and civil society organizations to
                        ensure that research translates into actionable solutions.
                    </p>
                    <p>
                        MoRPH’s initiatives combine rigorous research, community engagement, project management, and
                        knowledge sharing to address pressing challenges such as climate-induced displacement, health
                        inequities, and digital inclusion. By promoting interdisciplinary collaboration, MoRPH creates a
                        platform where innovative ideas are tested, refined, and transformed into impact-driven
                        outcomes.
                    </p>
                    <p>
                        Operating as an independent and non-partisan institution, MoRPH’s mission is to generate
                        knowledge, influence policy, and empower communities to shape a more just, inclusive, and
                        sustainable future. Through research, project management, capacity building, publications, and
                        dialogue forums, MoRPH positions itself as a catalyst for change in Bangladesh and beyond.
                    </p>
                </div>
            </div>
        </section>

        <!-- Mission & Vision -->
        <section class="py-20 bg-white">
            <div class="container mx-auto px-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                    <div class="reveal">
                        <h2 class="text-3xl font-bold text-secondary mb-6">Our Mission</h2>
                        <p class="text-gray-600 leading-relaxed mb-6">
                            To generate evidence-based knowledge, foster innovation, and promote sustainable solutions
                            that empower communities, influence policy, and strengthen governance for a just and
                            resilient society.
                        </p>
                        <h2 class="text-3xl font-bold text-secondary mb-6">Our Vision</h2>
                        <p class="text-gray-600 leading-relaxed">
                            To emerge as a leading center of excellence in research, partnerships, capacity building and
                            innovation, advancing inclusive development and addressing the most pressing challenges of
                            our time.
                        </p>
                    </div>
                    <div class="reveal">
                        <h4 class="text-xl font-bold text-secondary mb-4 text-center">MoRPH Organogram</h4>
                        <img src="/images/morph-organogram.png" alt="MoRPH Organogram"
                            class="rounded-2xl shadow-xl w-full border border-gray-100 p-2 bg-white">
                    </div>
                </div>
            </div>
        </section>

        <!-- Scope of Work & Achievements -->
        <section class="py-20 bg-gray-50">
            <div class="container mx-auto px-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    <!-- Scope of Work -->
