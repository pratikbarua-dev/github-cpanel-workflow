                    <h3 class="font-bold text-xl text-secondary mb-3">Interdisciplinary</h3>
                    <p class="text-gray-600 text-sm">Bridging gaps between diverse fields like health, environment,
                        and migration.</p>
                </div>
            </div>
        </div>
        </section>
    </main>

    <%- include('partials/footer') %>