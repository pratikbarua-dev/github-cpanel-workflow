                            <li class="flex items-start gap-3 text-gray-700">
                                <i class="fas fa-check-circle text-primary mt-1"></i>
                                <span>Partnership building among NGOs, academia, government, and civil society</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Achievements -->
                    <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 h-full reveal">
