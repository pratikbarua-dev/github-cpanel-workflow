                        <p class="text-gray-600 mb-6">MoRPH undertakes a wide range of activities, including:</p>
                        <ul class="space-y-3">
                            <li class="flex items-start gap-3 text-gray-700">
                                <i class="fas fa-check-circle text-primary mt-1"></i>
                                <span>Applied and academic research studies</span>
                            </li>
                            <li class="flex items-start gap-3 text-gray-700">
                                <i class="fas fa-check-circle text-primary mt-1"></i>
                                <span>Policy analysis and advocacy</span>
                            </li>
                            <li class="flex items-start gap-3 text-gray-700">
                                <i class="fas fa-check-circle text-primary mt-1"></i>
                                <span>Training, workshops, and professional courses</span>
                            </li>
                            <li class="flex items-start gap-3 text-gray-700">
                                <i class="fas fa-check-circle text-primary mt-1"></i>
                                <span>Community-based pilot interventions</span>
                            </li>
                            <li class="flex items-start gap-3 text-gray-700">
                                <i class="fas fa-check-circle text-primary mt-1"></i>
                                <span>Technical consultancy and advisory services</span>
                            </li>
                            <li class="flex items-start gap-3 text-gray-700">
                                <i class="fas fa-check-circle text-primary mt-1"></i>
