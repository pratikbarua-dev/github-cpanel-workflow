<%- include('partials/header', { title: 'Success' }) %>

    <main class="flex-1 bg-gray-50 flex items-center justify-center min-h-[60vh]">
        <div class="max-w-md w-full mx-4">
            <div class="bg-white p-8 rounded-2xl shadow-lg text-center border border-gray-100">
                <div
                    class="w-20 h-20 bg-green-100 text-green-500 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl shadow-sm">
                    <i class="fas fa-check"></i>
                </div>

                <h1 class="text-2xl font-bold text-gray-800 mb-2">Submission Received!</h1>
                <p class="text-gray-600 mb-8">Thank you for submitting <strong>
                        <%= form.title %>
                    </strong>. We have received your data securely.</p>

                <a href="/"
                    class="block w-full bg-gray-800 hover:bg-gray-900 text-white font-bold py-3 rounded-xl transition">
                    Return Home
                </a>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>