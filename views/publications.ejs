<%- include('partials/header') %>

    <section
        class="relative py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-white via-cyan-50/40 to-white min-h-screen">
        <div
            class="absolute top-0 right-0 -z-10 w-1/2 h-full bg-gradient-to-bl from-teal-50/50 to-transparent pointer-events-none">
        </div>

        <div class="max-w-7xl mx-auto">

            <div class="text-center mb-10">
                <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">
                    Latest Publications & Insights
                </h1>
                <p class="text-gray-500 text-lg">
                    Explore our recent research, reports, and community stories.
                </p>
            </div>

            <!-- Search Integration (Dynamic later) -->
            <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-10">
                <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
                    <div class="relative w-full sm:w-72">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                            <i class="fas fa-search"></i>
                        </div>
                        <input type="text"
                            class="block w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none shadow-sm text-sm"
                            placeholder="Search">
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
                <% if (publications.length> 0) { %>
                    <% publications.forEach(function(pub) { %>
                        <article
                            class="bg-white rounded-xl shadow-[0_2px_15px_-3px_rgba(0,0,0,0.07)] hover:shadow-lg transition-all duration-300 border border-gray-50 flex flex-col group overflow-hidden">
                            <!-- Heading Image -->
                            <% if (pub.heading_image) { %>
                                <div class="w-full h-40 overflow-hidden">
                                    <img src="<%= pub.heading_image %>" alt="<%= pub.title %>"
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                </div>
                                <% } %>

                                    <div class="p-4 flex-1 flex flex-col">
                                        <div class="flex-1">
                                            <h3
                                                class="text-base font-bold text-gray-900 leading-tight mb-2 group-hover:text-cyan-600 transition-colors">
                                                <%= pub.title %>
                                            </h3>
                                            <p class="text-xs text-gray-400 mb-3">
                                                <%= pub.published_date %>
                                            </p>
                                            <% if (pub.description) { %>
                                                <div class="text-sm text-gray-600 mb-4 line-clamp-3">
                                                    <%= pub.description.replace(/<[^>]*>?/gm, '').substring(0, 160)
                                                        %>...
                                                </div>
                                                <% } %>
                                        </div>
                                        <div class="flex flex-wrap gap-2 mt-auto pt-3 border-t border-gray-100">
                                            <a href="/publications/<%= pub.id %>"
                                                class="flex-1 px-3 py-2 text-xs font-medium text-center text-white bg-teal-600 rounded-lg hover:bg-teal-700 transition">
                                                <i class="fas fa-book-open mr-1"></i> Read More
                                            </a>
                                            <% if (pub.file_url) { %>
                                                <a href="<%= pub.file_url %>" target="_blank"
                                                    class="px-3 py-2 text-xs font-medium text-cyan-700 bg-cyan-50 rounded-lg hover:bg-cyan-100 transition"
                                                    title="Download PDF">
                                                    <i class="fas fa-file-download mr-1"></i> Download PDF
                                                </a>
                                                <% } %>
                                        </div>
                                    </div>
                        </article>
                        <% }); %>
                            <% } else { %>
                                <div class="col-span-full text-center py-12">
                                    <i class="fas fa-file-alt text-4xl text-gray-300 mb-4"></i>
                                    <p class="text-gray-500">No publications found.</p>
                                </div>
                                <% } %>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>