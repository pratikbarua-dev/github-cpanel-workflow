<%- include('partials/header') %>

    <section class="relative py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-white via-cyan-50/40 to-white flex-grow">

        <div class="max-w-6xl mx-auto">

            <div class="text-center mb-12">
                <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Contact Us</h1>
                <p class="text-gray-500 text-lg">Get in touch with MoRPH for collaborations, inquiries, or general
                    questions.</p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">

                <div
                    class="bg-white rounded-2xl shadow-lg shadow-cyan-900/5 p-8 border border-gray-100 flex flex-col h-full">
                    <div class="space-y-8 mb-8">
                        <div class="flex items-start gap-4">
                            <div
                                class="w-12 h-12 rounded-full bg-cyan-500 flex items-center justify-center text-white shrink-0 shadow-md shadow-cyan-200">
                                <i class="fas fa-map-marker-alt text-lg"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 text-lg">Head Office</h3>
                                <p class="text-gray-600 leading-relaxed text-sm">
                                    Holding No 6034, Village: Panchtikry (South Zone),<br>
                                    Ward: 09, Union: 4 No. Lokerpara, Upazila: Ghatail,<br>
                                    District: Tangail, Bangladesh.
                                </p>
                                <h3 class="font-bold text-gray-900 text-lg mt-4">Liaison Office</h3>
                                <p class="text-gray-600 leading-relaxed text-sm">
                                    SEL Centre (6th Floor), 29 West Panthapath,<br>
                                    Dhaka-1205, Bangladesh.
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div
                                class="w-12 h-12 rounded-full bg-teal-500 flex items-center justify-center text-white shrink-0 shadow-md shadow-teal-200">
                                <i class="fas fa-envelope text-lg"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 text-lg">Email</h3>
                                <p class="text-gray-600">morph@morphbangladesh.org</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div
                                class="w-12 h-12 rounded-full bg-cyan-600 flex items-center justify-center text-white shrink-0 shadow-md shadow-cyan-200">
                                <i class="fas fa-phone text-lg"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 text-lg">Phone</h3>
                                <p class="text-gray-600">+880-1755508971</p>
                            </div>
                        </div>
                    </div>
                    <!-- Google Map -->
                    <div
                        class="rounded-2xl overflow-hidden shadow-lg shadow-cyan-900/5 border border-gray-100 h-64 relative group mt-auto">
                        <iframe width="100%" height="100%" frameborder="0" scrolling="no" marginheight="0"
                            marginwidth="0" src="https://maps.google.com/maps?q=24.249979,89.920029&z=15&output=embed"
                            class="transition-all duration-700">
                        </iframe>
                        <div
                            class="absolute bottom-4 right-4 bg-white/90 backdrop-blur px-4 py-2 rounded-lg shadow-sm text-xs text-gray-500 pointer-events-none">
                            <i class="fas fa-map-pin text-primary mr-1"></i> Tangail, Bangladesh
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-2xl shadow-lg shadow-cyan-900/5 p-8 border border-gray-100">
                    <% if (locals.success) { %>
                        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4"
                            role="alert">
                            <strong class="font-bold">Success!</strong>
                            <span class="block sm:inline">
                                <%= success %>
                            </span>
                        </div>
                        <% } %>
                            <% if (locals.error) { %>
                                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4"
                                    role="alert">
                                    <strong class="font-bold">Error!</strong>
                                    <span class="block sm:inline">
                                        <%= error %>
                                    </span>
                                </div>
                                <% } %>

                                    <form action="/contact" method="POST" class="space-y-6">
                                        <div>
                                            <input type="text" name="name" placeholder="Name" required
                                                class="w-full px-4 py-3.5 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all placeholder-gray-400 text-gray-700">
                                        </div>

                                        <div>
                                            <input type="email" name="email" placeholder="Email" required
                                                class="w-full px-4 py-3.5 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all placeholder-gray-400 text-gray-700">
                                        </div>

                                        <div>
                                            <input type="text" name="subject" placeholder="Subject"
                                                class="w-full px-4 py-3.5 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all placeholder-gray-400 text-gray-700">
                                        </div>

                                        <div>
                                            <textarea name="message" placeholder="Message" rows="6" required
                                                class="w-full px-4 py-3.5 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all placeholder-gray-400 text-gray-700 resize-none"></textarea>
                                        </div>

                                        <div>
                                            <label class="block text-sm font-bold text-gray-700 mb-2">Security
                                                Check</label>
                                            <div class="flex items-center gap-4">
                                                <div class="bg-gray-100 p-2 rounded-lg border border-gray-300">
                                                    <img src="/captcha" alt="CAPTCHA"
                                                        class="h-12 rounded cursor-pointer"
                                                        onclick="this.src='/captcha?'+Math.random()"
                                                        title="Click to refresh">
                                                </div>
                                                <input type="text" name="captcha" placeholder="Enter code" required
                                                    class="flex-grow px-4 py-3.5 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all placeholder-gray-400 text-gray-700">
                                            </div>
                                        </div>

                                        <button type="submit"
                                            class="w-full py-4 bg-gradient-to-r from-cyan-500 to-teal-500 hover:from-cyan-600 hover:to-teal-600 text-white font-bold text-lg rounded-xl shadow-lg shadow-cyan-500/25 transition-all transform hover:-translate-y-0.5 active:translate-y-0">
                                            Send Message
                                        </button>
                                    </form>
                </div>

            </div>


        </div>
    </section>

    <%- include('partials/footer') %>